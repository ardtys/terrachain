---
import Card from '@components/shared/Card.astro';
import type { LucideIcon } from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  icon?: any;
  colSpan?: 1 | 2;
  stagger?: number;
  color?: 'accent' | 'gold' | 'copper' | 'green' | 'forest' | 'sand';
}

const { title, description, icon: Icon, colSpan = 1, stagger = 1, color = 'accent' } = Astro.props;

const colorMap = {
  accent: {
    bg: 'from-accent/15 to-accent/5',
    border: 'border-accent/30',
    text: 'text-accent',
    glow: 'group-hover:shadow-[0_0_30px_rgba(196,184,154,0.25)]',
    iconBg: 'bg-accent/10',
    lineGradient: 'from-accent/60 to-accent/20',
  },
  gold: {
    bg: 'from-gold/15 to-gold/5',
    border: 'border-gold/30',
    text: 'text-gold',
    glow: 'group-hover:shadow-[0_0_30px_rgba(212,175,55,0.25)]',
    iconBg: 'bg-gold/10',
    lineGradient: 'from-gold/60 to-gold/20',
  },
  copper: {
    bg: 'from-copper/15 to-copper/5',
    border: 'border-copper/30',
    text: 'text-copper',
    glow: 'group-hover:shadow-[0_0_30px_rgba(184,115,51,0.25)]',
    iconBg: 'bg-copper/10',
    lineGradient: 'from-copper/60 to-copper/20',
  },
  green: {
    bg: 'from-green/15 to-green/5',
    border: 'border-green/30',
    text: 'text-green',
    glow: 'group-hover:shadow-[0_0_30px_rgba(124,154,110,0.25)]',
    iconBg: 'bg-green/10',
    lineGradient: 'from-green/60 to-green/20',
  },
  forest: {
    bg: 'from-green/15 to-accent/5',
    border: 'border-green/30',
    text: 'text-green',
    glow: 'group-hover:shadow-[0_0_30px_rgba(124,154,110,0.25)]',
    iconBg: 'bg-green/10',
    lineGradient: 'from-green/60 to-accent/20',
  },
  sand: {
    bg: 'from-sand/15 to-accent/5',
    border: 'border-sand/30',
    text: 'text-sand',
    glow: 'group-hover:shadow-[0_0_30px_rgba(232,224,208,0.2)]',
    iconBg: 'bg-sand/10',
    lineGradient: 'from-sand/60 to-sand/20',
  },
};

const colors = colorMap[color];
---

<Card colSpan={colSpan} class={`min-h-[180px] group feature-card overflow-hidden transition-all duration-300 ${colors.glow}`} stagger={stagger}>
  <!-- Gradient background on hover -->
  <div class={`absolute inset-0 bg-gradient-to-br ${colors.bg} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

  <!-- Animated corner accent -->
  <div class="absolute top-0 right-0 w-20 h-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    <div class={`absolute top-4 right-4 w-8 h-0.5 bg-gradient-to-l ${colors.lineGradient}`}></div>
    <div class={`absolute top-4 right-4 w-0.5 h-8 bg-gradient-to-t ${colors.lineGradient}`}></div>
  </div>

  <div class="relative z-10">
    {Icon && (
      <div class={`w-12 h-12 rounded-xl ${colors.iconBg} border ${colors.border} flex items-center justify-center mb-4 transition-all duration-300 group-hover:scale-110 group-hover:rotate-3`}>
        <Icon class={`w-6 h-6 ${colors.text} transition-all duration-300`} />
      </div>
    )}

    <h3 class="heading-mono text-base text-text-primary mb-2 group-hover:text-gradient-animated transition-all duration-300">{title}</h3>
    <p class="text-sm text-text-secondary leading-relaxed group-hover:text-text-primary/80 transition-colors duration-300">{description}</p>
  </div>

  <!-- Bottom line animation -->
  <div class="absolute bottom-0 left-0 right-0 h-0.5 overflow-hidden">
    <div class={`h-full w-full bg-gradient-to-r ${colors.lineGradient} translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500`}></div>
  </div>
</Card>

<style>
  .feature-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }
</style>
