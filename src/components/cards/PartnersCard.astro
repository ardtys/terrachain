---
import Card from '@components/shared/Card.astro';
import SectionLabel from '@components/shared/SectionLabel.astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

const partners = [
  { name: 'World Bank', subtitle: 'Compatible' },
  { name: 'UN-Habitat', subtitle: 'Aligned' },
  { name: 'Blockchain', subtitle: 'Built on' },
];
---

<Card colSpan={1} class="min-h-[200px]" stagger={stagger}>
  <SectionLabel class="mb-4">Institutional Partners</SectionLabel>

  <div class="space-y-4">
    {partners.map((partner) => (
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-lg bg-surface-hover border border-border flex items-center justify-center text-text-secondary group-hover:border-border-hover transition-colors">
          <span class="text-xs font-mono font-semibold">{partner.name.charAt(0)}</span>
        </div>
        <div>
          <p class="text-sm text-text-primary font-mono">{partner.name}</p>
          <p class="text-xs text-text-muted">{partner.subtitle}</p>
        </div>
      </div>
    ))}
  </div>
</Card>
