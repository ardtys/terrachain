---
import Card from '@components/shared/Card.astro';

interface Props {
  name: string;
  role: string;
  bio: string;
  avatar?: string;
  stagger?: number;
}

const { name, role, bio, avatar, stagger = 1 } = Astro.props;

// Generate initials from name
const initials = name.split(' ').map(n => n[0]).join('').toUpperCase();
---

<Card colSpan={1} class="min-h-[200px]" stagger={stagger}>
  <div class="flex items-start gap-4 mb-4">
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        class="w-12 h-12 rounded-full object-cover border border-border"
      />
    ) : (
      <div class="w-12 h-12 rounded-full bg-surface-hover border border-border flex items-center justify-center text-text-secondary font-mono text-sm">
        {initials}
      </div>
    )}

    <div>
      <h4 class="text-text-primary font-mono text-sm">{name}</h4>
      <p class="text-text-muted text-xs">{role}</p>
    </div>
  </div>

  <p class="text-text-secondary text-sm leading-relaxed">{bio}</p>
</Card>
