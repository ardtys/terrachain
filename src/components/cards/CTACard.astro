---
import Card from '@components/shared/Card.astro';
import Mascot from '@components/decorative/Mascot.astro';
import { ArrowRight, Sparkles } from 'lucide-astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;
---

<Card colSpan={1} class="min-h-[180px] sm:min-h-[200px] md:min-h-[220px] flex flex-col justify-between overflow-hidden group cta-card" stagger={stagger} glow accent>
  <!-- Animated gradient background -->
  <div class="absolute inset-0 bg-gradient-animated opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <!-- Glowing orbs - Earth tones -->
  <div class="absolute -top-10 -right-10 w-24 sm:w-32 h-24 sm:h-32 bg-gradient-to-br from-accent/20 to-gold/20 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
  <div class="absolute -bottom-10 -left-10 w-20 sm:w-28 h-20 sm:h-28 bg-gradient-to-tr from-green/15 to-copper/15 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700 delay-100"></div>

  <!-- Floating particles - hidden on mobile -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none hidden sm:block">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>

  <!-- Animated border glow -->
  <div class="absolute inset-0 rounded-[inherit] border-glow opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

  <div class="relative z-10">
    <div class="flex items-center gap-2 mb-2 sm:mb-3">
      <div class="sparkle-container">
        <Sparkles class="w-4 h-4 sm:w-5 sm:h-5 text-gold sparkle-icon" />
      </div>
      <span class="text-[10px] sm:text-xs text-gradient-animated font-mono uppercase tracking-wider font-bold">Get Started</span>
    </div>

    <p class="text-text-secondary text-xs sm:text-sm leading-relaxed mb-3 sm:mb-5">
      Interested in bringing TerraChain to your jurisdiction?
    </p>

    <a
      href="mailto:hello@terrachain.xyz"
      class="btn btn-primary inline-flex items-center gap-2 no-underline group/btn card-shine ripple-effect text-xs sm:text-sm py-2 sm:py-3 px-3 sm:px-5"
    >
      <span>Request a Demo</span>
      <ArrowRight class="w-3.5 h-3.5 sm:w-4 sm:h-4 transition-all duration-300 group-hover/btn:translate-x-1 group-hover/btn:scale-125" />
    </a>

    <p class="mt-2 sm:mt-3 text-[10px] sm:text-xs text-text-muted">
      Or email us at <a href="mailto:hello@terrachain.xyz" class="text-accent hover:text-gold transition-colors">hello@terrachain.xyz</a>
    </p>
  </div>

  <div class="flex justify-end -mr-2 -mb-2 relative z-10 mascot-wrapper scale-75 sm:scale-100">
    <Mascot size="sm" pose="waving" />
  </div>
</Card>

<style>
  .cta-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }

  .bg-gradient-animated {
    background: linear-gradient(
      135deg,
      rgba(196, 184, 154, 0.08),
      rgba(212, 175, 55, 0.06),
      rgba(124, 154, 110, 0.06)
    );
    animation: gradientMove 4s ease infinite;
  }

  @keyframes gradientMove {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .text-gold {
    color: var(--color-gold);
  }

  .border-glow {
    border: 2px solid transparent;
    background: linear-gradient(var(--color-surface), var(--color-surface)) padding-box,
                linear-gradient(135deg, var(--color-accent), var(--color-gold), var(--color-green)) border-box;
  }

  .sparkle-container {
    position: relative;
  }

  .sparkle-icon {
    animation: sparkleRotate 3s ease-in-out infinite;
  }

  @keyframes sparkleRotate {
    0%, 100% {
      transform: rotate(0deg) scale(1);
      filter: drop-shadow(0 0 4px var(--color-gold));
    }
    25% {
      transform: rotate(10deg) scale(1.1);
      filter: drop-shadow(0 0 8px var(--color-gold));
    }
    50% {
      transform: rotate(0deg) scale(1);
      filter: drop-shadow(0 0 4px var(--color-gold));
    }
    75% {
      transform: rotate(-10deg) scale(1.1);
      filter: drop-shadow(0 0 8px var(--color-gold));
    }
  }

  .mascot-wrapper {
    transition: transform 0.3s ease;
  }

  .group:hover .mascot-wrapper {
    transform: scale(1.1) translateY(-5px);
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    opacity: 0;
  }

  .group:hover .particle {
    animation: floatUpEarth 3s ease-in-out infinite;
  }

  .particle-1 {
    background: var(--color-accent);
    left: 10%;
    bottom: 20%;
    animation-delay: 0s;
  }

  .particle-2 {
    background: var(--color-gold);
    left: 30%;
    bottom: 10%;
    animation-delay: 0.5s;
  }

  .particle-3 {
    background: var(--color-copper);
    left: 50%;
    bottom: 30%;
    animation-delay: 1s;
  }

  .particle-4 {
    background: var(--color-green);
    left: 70%;
    bottom: 15%;
    animation-delay: 1.5s;
  }

  .particle-5 {
    background: var(--color-gold);
    left: 90%;
    bottom: 25%;
    animation-delay: 2s;
  }

  @keyframes floatUpEarth {
    0% {
      opacity: 0;
      transform: translateY(0) scale(0);
    }
    10% {
      opacity: 0.8;
      transform: translateY(-10px) scale(1);
    }
    90% {
      opacity: 0.8;
    }
    100% {
      opacity: 0;
      transform: translateY(-100px) scale(0.5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .particle,
    .sparkle-icon,
    .bg-gradient-animated {
      animation: none !important;
    }
  }
</style>
