---
import Card from '@components/shared/Card.astro';

interface Props {
  value: string;
  label: string;
  source?: string;
  stagger?: number;
  color?: 'accent' | 'green' | 'gold' | 'copper' | 'forest';
  animate?: boolean;
}

const { value, label, source, stagger = 1, color = 'accent', animate = true } = Astro.props;

const colorConfig = {
  accent: {
    gradient: 'from-accent to-gold',
    bg: 'bg-accent/10',
    glow: 'rgba(196, 184, 154, 0.3)',
    border: 'border-accent/20',
  },
  green: {
    gradient: 'from-green to-accent',
    bg: 'bg-green/10',
    glow: 'rgba(124, 154, 110, 0.3)',
    border: 'border-green/20',
  },
  gold: {
    gradient: 'from-gold to-copper',
    bg: 'bg-gold/10',
    glow: 'rgba(212, 175, 55, 0.3)',
    border: 'border-gold/20',
  },
  copper: {
    gradient: 'from-copper to-gold',
    bg: 'bg-copper/10',
    glow: 'rgba(184, 115, 51, 0.3)',
    border: 'border-copper/20',
  },
  forest: {
    gradient: 'from-green to-accent',
    bg: 'bg-green/10',
    glow: 'rgba(124, 154, 110, 0.3)',
    border: 'border-green/20',
  },
};

const config = colorConfig[color];

// Parse numeric value for animation
const numericMatch = value.match(/^([<>]?)(\$?)([\d.]+)([A-Za-z%+]*)?$/);
const prefix = numericMatch ? (numericMatch[1] + numericMatch[2]) : '';
const numericValue = numericMatch ? parseFloat(numericMatch[3]) : 0;
const suffix = numericMatch ? (numericMatch[4] || '') : '';
const hasDecimals = numericMatch ? numericMatch[3].includes('.') : false;
---

<Card colSpan={1} class="flex flex-col justify-center min-h-[180px] group stat-card overflow-hidden" stagger={stagger} glow>
  <!-- Animated background glow orbs -->
  <div class={`absolute -top-10 -right-10 w-40 h-40 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-all duration-500 ${config.bg}`}></div>
  <div class={`absolute -bottom-10 -left-10 w-32 h-32 rounded-full blur-2xl opacity-0 group-hover:opacity-50 transition-all duration-700 ${config.bg}`}></div>

  <!-- Animated particles on hover -->
  <div class="particles-container">
    <div class="stat-particle stat-particle-1" style={`--particle-color: ${config.glow}`}></div>
    <div class="stat-particle stat-particle-2" style={`--particle-color: ${config.glow}`}></div>
    <div class="stat-particle stat-particle-3" style={`--particle-color: ${config.glow}`}></div>
  </div>

  <div class="relative z-10">
    <span
      class={`stat-number-vibrant mb-3 block transition-all duration-300 group-hover:scale-105 bg-gradient-to-r ${config.gradient} bg-clip-text text-transparent`}
      style={`--glow-color: ${config.glow}`}
      data-value={value}
      data-animate-counter={animate && numericValue > 0 ? '' : undefined}
      data-counter-prefix={prefix}
      data-counter-value={numericValue}
      data-counter-suffix={suffix}
      data-counter-decimals={hasDecimals ? '1' : '0'}
    >
      {value}
    </span>
    <p class="text-text-secondary text-sm leading-snug group-hover:text-text-primary transition-colors duration-300">{label}</p>
    {source && (
      <p class="text-text-muted text-xs mt-3 italic opacity-60 group-hover:opacity-100 transition-opacity">&mdash; {source}</p>
    )}
  </div>

  <!-- Animated corner accent -->
  <div class="absolute bottom-4 right-4 w-10 h-10 opacity-30 group-hover:opacity-60 transition-all duration-300 group-hover:rotate-12">
    <svg viewBox="0 0 32 32" class="w-full h-full">
      <rect x="2" y="2" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" rx="6" class="text-accent"/>
      <circle cx="16" cy="16" r="4" fill="currentColor" class="text-accent animate-pulse"/>
    </svg>
  </div>

  <!-- Border glow effect -->
  <div class={`absolute inset-0 rounded-[inherit] border-2 ${config.border} opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}></div>
</Card>

<style>
  .stat-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }

  .stat-number-vibrant {
    font-family: var(--font-mono);
    font-size: var(--font-size-5xl);
    font-weight: 600;
    line-height: 1;
    letter-spacing: var(--letter-spacing-tight);
    background-size: 200% auto;
    animation: shimmerText 3s ease-in-out infinite;
    font-variant-numeric: tabular-nums;
    filter: drop-shadow(0 0 15px var(--glow-color));
  }

  .group:hover .stat-number-vibrant {
    filter: drop-shadow(0 0 25px var(--glow-color));
    animation: shimmerText 1.5s ease-in-out infinite;
  }

  @keyframes shimmerText {
    0%, 100% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
  }

  .particles-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .stat-particle {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--particle-color);
    opacity: 0;
  }

  .group:hover .stat-particle {
    animation: floatParticle 3s ease-in-out infinite;
  }

  .stat-particle-1 {
    left: 20%;
    animation-delay: 0s;
  }

  .stat-particle-2 {
    left: 50%;
    animation-delay: 0.7s;
  }

  .stat-particle-3 {
    left: 80%;
    animation-delay: 1.4s;
  }

  @keyframes floatParticle {
    0% {
      bottom: 0;
      opacity: 0;
      transform: scale(0);
    }
    10% {
      opacity: 0.8;
      transform: scale(1);
    }
    90% {
      opacity: 0.8;
    }
    100% {
      bottom: 100%;
      opacity: 0;
      transform: scale(0.5);
    }
  }
</style>

<script>
  // Animated counter with Intersection Observer
  const counters = document.querySelectorAll('[data-animate-counter]');

  const animateCounter = (element: HTMLElement) => {
    const prefix = element.dataset.counterPrefix || '';
    const targetValue = parseFloat(element.dataset.counterValue || '0');
    const suffix = element.dataset.counterSuffix || '';
    const decimals = parseInt(element.dataset.counterDecimals || '0');

    const duration = 2000;
    const startTime = performance.now();
    const startValue = 0;

    const easeOutQuart = function(t) { return 1 - Math.pow(1 - t, 4); };

    const updateCounter = function(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const easedProgress = easeOutQuart(progress);

      const currentValue = startValue + (targetValue - startValue) * easedProgress;
      const displayValue = decimals > 0 ? currentValue.toFixed(decimals) : Math.round(currentValue);

      element.textContent = `${prefix}${displayValue}${suffix}`;

      if (progress < 1) {
        requestAnimationFrame(updateCounter);
      }
    };

    requestAnimationFrame(updateCounter);
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const element = entry.target;
          if (!element.dataset.animated) {
            element.dataset.animated = 'true';
            animateCounter(element);
          }
          observer.unobserve(element);
        }
      });
    },
    { threshold: 0.5 }
  );

  counters.forEach((counter) => observer.observe(counter));
</script>
