---
import Card from '@components/shared/Card.astro';
import { Copy, Check, FileCode2 } from 'lucide-astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

const contractAddress = "0x0000000000000000000000000000000000000000";
---

<Card colSpan={2} class="min-h-[120px] md:min-h-[140px] flex flex-col justify-center group contract-card overflow-hidden" stagger={stagger} glow>
  <!-- Background glow -->
  <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-all duration-500 bg-accent/10"></div>
  <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full blur-2xl opacity-0 group-hover:opacity-50 transition-all duration-700 bg-gold/10"></div>

  <div class="relative z-10">
    <div class="flex items-center gap-2 mb-2 md:mb-3">
      <FileCode2 class="w-4 h-4 text-accent flex-shrink-0" />
      <span class="text-xs text-accent font-mono uppercase tracking-wider font-semibold">Contract Address</span>
    </div>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-3">
      <div class="contract-address-wrapper flex-1 min-w-0">
        <code class="contract-address text-text-primary font-mono text-xs sm:text-sm md:text-base bg-surface-alt/50 px-3 sm:px-4 py-2 sm:py-2.5 rounded-lg border border-border/50 block overflow-x-auto whitespace-nowrap group-hover:border-accent/30 transition-colors duration-300 scrollbar-hide">
          {contractAddress}
        </code>
      </div>

      <button
        id="copy-contract-btn"
        class="copy-btn flex items-center justify-center gap-2 sm:gap-0 w-full sm:w-10 h-10 rounded-lg bg-surface-alt/50 border border-border/50 hover:border-accent/50 active:border-accent/50 hover:bg-accent/10 active:bg-accent/10 transition-all duration-300 group/btn flex-shrink-0"
        data-address={contractAddress}
        aria-label="Copy contract address"
      >
        <Copy class="w-4 h-4 text-text-secondary group-hover/btn:text-accent transition-colors copy-icon" />
        <Check class="w-4 h-4 text-green hidden check-icon" />
        <span class="sm:hidden text-xs text-text-secondary group-hover/btn:text-accent copy-text">Copy</span>
        <span class="sm:hidden text-xs text-green hidden copied-text">Copied!</span>
      </button>
    </div>

    <p class="text-text-muted text-xs mt-2 md:mt-3 hidden sm:block">
      Click to copy the contract address
    </p>
  </div>

  <!-- Corner decoration - hidden on mobile -->
  <div class="absolute bottom-4 right-4 w-8 h-8 opacity-20 group-hover:opacity-40 transition-opacity duration-300 hidden sm:block">
    <svg viewBox="0 0 32 32" class="w-full h-full text-accent">
      <rect x="4" y="4" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" rx="4"/>
      <path d="M10 16h12M16 10v12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </div>
</Card>

<style>
  .contract-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }

  .contract-address {
    letter-spacing: 0.02em;
  }

  /* Hide scrollbar but keep functionality */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .copy-btn:active {
    transform: scale(0.97);
  }

  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: block;
  }

  .copy-btn.copied .copy-text {
    display: none;
  }

  .copy-btn.copied .copied-text {
    display: inline;
  }

  /* Touch feedback for mobile */
  @media (hover: none) {
    .copy-btn:active {
      background: rgba(196, 184, 154, 0.15);
      border-color: rgba(196, 184, 154, 0.5);
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-contract-btn');

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const address = copyBtn.dataset.address;

      if (address) {
        try {
          await navigator.clipboard.writeText(address);
          copyBtn.classList.add('copied');

          setTimeout(() => {
            copyBtn.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  }
</script>
