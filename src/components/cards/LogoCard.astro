---
import Card from '@components/shared/Card.astro';

interface Props {
  href?: string;
  stagger?: number;
}

const { href = '#', stagger = 1 } = Astro.props;
---

<Card colSpan={1} href={href} external class="min-h-[120px] sm:min-h-[140px] md:min-h-[160px] flex items-center justify-center relative" stagger={stagger}>
  <!-- Decorative circles - smaller on mobile -->
  <div class="absolute top-3 left-3 sm:top-4 sm:left-4 w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent opacity-20"></div>
  <div class="absolute top-3 right-8 sm:top-4 sm:right-12 w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-text-secondary opacity-15 hidden sm:block"></div>
  <div class="absolute bottom-8 left-4 sm:bottom-12 sm:left-6 w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-text-muted opacity-20 hidden sm:block"></div>
  <div class="absolute bottom-6 right-4 sm:bottom-8 sm:right-6 w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent opacity-15"></div>

  <!-- Blockchain logo (simplified) -->
  <svg viewBox="0 0 120 20" class="w-28 sm:w-32 md:w-36 text-text-primary">
    <path
      d="M7.5 16.5L0 9h10l7.5-7.5L25 9H15L7.5 16.5z"
      fill="currentColor"
      class="opacity-80"
    />
    <text x="30" y="14" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">
      Blockchain
    </text>
  </svg>
</Card>
