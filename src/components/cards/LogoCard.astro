---
import Card from '@components/shared/Card.astro';

interface Props {
  href?: string;
  stagger?: number;
}

const { href = '#', stagger = 1 } = Astro.props;
---

<Card colSpan={1} href={href} external class="min-h-[160px] flex items-center justify-center relative" stagger={stagger}>
  <!-- Decorative circles -->
  <div class="absolute top-4 left-4 w-3 h-3 rounded-full bg-accent opacity-20"></div>
  <div class="absolute top-4 right-12 w-2 h-2 rounded-full bg-text-secondary opacity-15"></div>
  <div class="absolute bottom-12 left-6 w-2 h-2 rounded-full bg-text-muted opacity-20"></div>
  <div class="absolute bottom-8 right-6 w-3 h-3 rounded-full bg-accent opacity-15"></div>

  <!-- Blockchain logo (simplified) -->
  <svg viewBox="0 0 120 20" class="w-36 text-text-primary">
    <path
      d="M7.5 16.5L0 9h10l7.5-7.5L25 9H15L7.5 16.5z"
      fill="currentColor"
      class="opacity-80"
    />
    <text x="30" y="14" font-family="IBM Plex Mono, monospace" font-size="11" fill="currentColor">
      Blockchain
    </text>
  </svg>
</Card>
