---
import Card from '@components/shared/Card.astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

const phases = [
  {
    phase: 'Phase 1',
    name: 'Pilot District',
    timeline: 'Mo 1-6',
    target: '1K parcels',
    status: 'active',
    progress: 65
  },
  {
    phase: 'Phase 2',
    name: 'Validation',
    timeline: 'Mo 7-12',
    target: '50K parcels',
    status: 'upcoming',
    progress: 0
  },
  {
    phase: 'Phase 3',
    name: 'National Scale',
    timeline: 'Year 2',
    target: '500K parcels',
    status: 'upcoming',
    progress: 0
  },
  {
    phase: 'Phase 4',
    name: 'Global Protocol',
    timeline: 'Year 3+',
    target: 'Multi-country',
    status: 'upcoming',
    progress: 0
  }
];
---

<Card colSpan={3} class="min-h-[200px] sm:min-h-[180px] md:min-h-[160px] overflow-hidden" stagger={stagger} accent>
  <!-- Animated background line - hidden on mobile -->
  <div class="absolute top-1/2 left-0 right-0 h-px hidden md:block">
    <div class="h-full bg-gradient-to-r from-transparent via-accent/30 to-transparent animate-reveal-line"></div>
  </div>

  <div class="relative flex flex-col md:flex-row md:items-center gap-4 sm:gap-5 md:gap-6">
    {phases.map((item, index) => (
      <div class="flex-1 flex items-center group" style={`--index: ${index}`}>
        <div class="flex items-center gap-3 sm:gap-4 w-full">
          <!-- Phase indicator -->
          <div class="relative">
            <div class:list={[
              "w-4 h-4 sm:w-5 sm:h-5 rounded-full border-2 flex-shrink-0 transition-all duration-500 flex items-center justify-center",
              item.status === 'active'
                ? "bg-accent border-accent animate-pulse-glow"
                : "bg-surface-hover border-border-hover group-hover:border-accent group-hover:scale-110"
            ]}>
              {item.status === 'active' && (
                <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-bg"></div>
              )}
            </div>
            {/* Ripple effect for active phase - hidden on mobile */}
            {item.status === 'active' && (
              <div class="absolute inset-0 rounded-full border-2 border-accent animate-ping opacity-30 hidden sm:block"></div>
            )}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 sm:gap-2 mb-0.5 sm:mb-1">
              <span class="text-[10px] sm:text-xs text-text-muted font-mono">{item.phase}</span>
              <span class="text-[10px] sm:text-xs text-text-muted">·</span>
              <span class:list={[
                "text-[10px] sm:text-xs font-mono",
                item.status === 'active' ? "text-accent" : "text-text-muted"
              ]}>{item.timeline}</span>
            </div>
            <h4 class="text-xs sm:text-sm text-text-primary font-mono mb-0.5 sm:mb-1 group-hover:text-gradient-warm transition-all truncate">{item.name}</h4>
            <p class="text-[10px] sm:text-xs text-text-secondary">{item.target}</p>

            {/* Progress bar for active phase */}
            {item.status === 'active' && (
              <div class="mt-1.5 sm:mt-2 h-1 bg-surface-hover rounded-full overflow-hidden">
                <div
                  class="h-full bg-gradient-to-r from-accent to-gold rounded-full progress-bar"
                  style={`--target-width: ${item.progress}%`}
                ></div>
              </div>
            )}
          </div>
        </div>

        {/* Connecting line */}
        {index < phases.length - 1 && (
          <div class="hidden md:block flex-shrink-0 w-6 lg:w-8 h-px bg-gradient-to-r from-border to-transparent mx-1 lg:mx-2" />
        )}
      </div>
    ))}
  </div>
</Card>

<style>
  .progress-bar {
    width: 0;
    animation: fillProgress 1.5s ease-out 0.5s forwards;
  }

  @keyframes fillProgress {
    to {
      width: var(--target-width);
    }
  }

  [style*="--index"] {
    animation: slideInPhase 0.6s ease-out forwards;
    animation-delay: calc(var(--index) * 150ms);
    opacity: 0;
    transform: translateY(10px);
  }

  @keyframes slideInPhase {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
