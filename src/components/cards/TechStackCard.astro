---
import Card from '@components/shared/Card.astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

const techStack = [
  { name: 'Blockchain', category: 'Blockchain', percentage: 100, color: '#22d3ee', glowColor: 'rgba(34, 211, 238, 0.4)' },
  { name: 'Rust/Anchor', category: 'Smart Contracts', percentage: 85, color: '#a855f7', glowColor: 'rgba(168, 85, 247, 0.4)' },
  { name: 'PostGIS', category: 'Geospatial', percentage: 70, color: '#10b981', glowColor: 'rgba(16, 185, 129, 0.4)' },
  { name: 'Arweave', category: 'Storage', percentage: 55, color: '#ec4899', glowColor: 'rgba(236, 72, 153, 0.4)' },
  { name: 'React Native', category: 'Mobile', percentage: 45, color: '#f97316', glowColor: 'rgba(249, 115, 22, 0.4)' },
  { name: 'SvelteKit', category: 'Admin Portal', percentage: 35, color: '#eab308', glowColor: 'rgba(234, 179, 8, 0.4)' },
  { name: 'Kafka', category: 'Event Stream', percentage: 30, color: '#3b82f6', glowColor: 'rgba(59, 130, 246, 0.4)' },
];
---

<Card colSpan={2} class="min-h-[280px] tech-stack-card" stagger={stagger} glow>
  <!-- Background gradient orbs -->
  <div class="absolute -top-20 -right-20 w-40 h-40 bg-gradient-to-br from-cyan-500/10 to-purple-500/10 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gradient-to-tr from-pink-500/10 to-emerald-500/10 rounded-full blur-2xl"></div>

  <h3 class="heading-mono text-lg text-text-primary mb-6 relative z-10">
    <span class="text-gradient-animated">Technology Stack</span>
  </h3>

  <div class="space-y-4 relative z-10">
    {techStack.map((tech, index) => (
      <div class="group flex items-center gap-3 tech-row" style={`--delay: ${index * 100}ms; --bar-color: ${tech.color}; --glow-color: ${tech.glowColor}`}>
        <span class="w-24 text-xs font-mono truncate transition-all duration-300 group-hover:font-bold" style={`color: ${tech.color}`}>
          {tech.name}
        </span>
        <div class="flex-1 h-6 bg-surface-hover rounded-full overflow-hidden relative">
          <!-- Animated progress bar -->
          <div
            class="h-full rounded-full progress-bar relative overflow-hidden"
            style={`width: ${tech.percentage}%; background: linear-gradient(90deg, ${tech.color} 0%, ${tech.color}88 100%); animation-delay: var(--delay);`}
          >
            <!-- Shimmer effect -->
            <div class="shimmer-effect"></div>
            <!-- Pulse dot at end -->
            <div class="absolute right-1 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-white/50 animate-pulse"></div>
          </div>
          <!-- Glow effect on hover -->
          <div class="bar-glow"></div>
        </div>
        <span class="w-24 text-xs text-text-muted font-mono text-right group-hover:text-text-secondary transition-colors">
          {tech.category}
        </span>
      </div>
    ))}
  </div>

  <!-- Bottom decoration with gradient -->
  <div class="absolute bottom-4 left-4 right-4 h-px bg-gradient-to-r from-cyan-500/20 via-purple-500/40 to-pink-500/20"></div>
</Card>

<style>
  .tech-stack-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }

  .progress-bar {
    animation: progressFill 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
    width: 0;
  }

  @keyframes progressFill {
    from {
      width: 0;
    }
  }

  .shimmer-effect {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transform: translateX(-100%);
    transition: transform 0.8s ease;
  }

  .tech-row:hover .shimmer-effect {
    transform: translateX(100%);
  }

  .bar-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    box-shadow: inset 0 0 20px var(--glow-color, rgba(255,255,255,0.1));
    border-radius: 9999px;
  }

  .tech-row:hover .bar-glow {
    opacity: 1;
  }

  .tech-row {
    transition: transform 0.2s ease;
  }

  .tech-row:hover {
    transform: translateX(4px);
  }

  .tech-row:hover .progress-bar {
    box-shadow: 0 0 20px var(--glow-color, rgba(255,255,255,0.2));
  }
</style>
