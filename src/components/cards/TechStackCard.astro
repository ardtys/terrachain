---
import Card from '@components/shared/Card.astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

const techStack = [
  { name: 'Blockchain', category: 'Blockchain', percentage: 100, color: '#c4b89a', glowColor: 'rgba(196, 184, 154, 0.4)' },
  { name: 'Rust/Anchor', category: 'Smart Contracts', percentage: 85, color: '#d4af37', glowColor: 'rgba(212, 175, 55, 0.4)' },
  { name: 'PostGIS', category: 'Geospatial', percentage: 70, color: '#7c9a6e', glowColor: 'rgba(124, 154, 110, 0.4)' },
  { name: 'Arweave', category: 'Storage', percentage: 55, color: '#b87333', glowColor: 'rgba(184, 115, 51, 0.4)' },
  { name: 'React Native', category: 'Mobile', percentage: 45, color: '#a09882', glowColor: 'rgba(160, 152, 130, 0.4)' },
  { name: 'SvelteKit', category: 'Admin Portal', percentage: 35, color: '#cd7f32', glowColor: 'rgba(205, 127, 50, 0.4)' },
  { name: 'Kafka', category: 'Event Stream', percentage: 30, color: '#8b7355', glowColor: 'rgba(139, 115, 85, 0.4)' },
];
---

<Card colSpan={2} class="min-h-[240px] sm:min-h-[260px] md:min-h-[280px] tech-stack-card" stagger={stagger} glow>
  <!-- Background gradient orbs -->
  <div class="absolute -top-20 -right-20 w-28 sm:w-40 h-28 sm:h-40 bg-gradient-to-br from-accent/10 to-gold/10 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-10 -left-10 w-24 sm:w-32 h-24 sm:h-32 bg-gradient-to-tr from-green/10 to-accent/10 rounded-full blur-2xl"></div>

  <h3 class="heading-mono text-base sm:text-lg text-text-primary mb-4 sm:mb-6 relative z-10">
    <span class="text-gradient-animated">Technology Stack</span>
  </h3>

  <div class="space-y-2.5 sm:space-y-3 md:space-y-4 relative z-10">
    {techStack.map((tech, index) => (
      <div class="group flex items-center gap-2 sm:gap-3 tech-row" style={`--delay: ${index * 100}ms; --bar-color: ${tech.color}; --glow-color: ${tech.glowColor}`}>
        <span class="w-16 sm:w-20 md:w-24 text-[10px] sm:text-xs font-mono truncate transition-all duration-300 group-hover:font-bold" style={`color: ${tech.color}`}>
          {tech.name}
        </span>
        <div class="flex-1 h-4 sm:h-5 md:h-6 bg-surface-hover rounded-full overflow-hidden relative">
          <!-- Animated progress bar -->
          <div
            class="h-full rounded-full progress-bar relative overflow-hidden"
            style={`width: ${tech.percentage}%; background: linear-gradient(90deg, ${tech.color} 0%, ${tech.color}88 100%); animation-delay: var(--delay);`}
          >
            <!-- Shimmer effect -->
            <div class="shimmer-effect"></div>
            <!-- Pulse dot at end - hidden on mobile -->
            <div class="absolute right-1 top-1/2 -translate-y-1/2 w-1.5 sm:w-2 h-1.5 sm:h-2 rounded-full bg-white/50 animate-pulse hidden sm:block"></div>
          </div>
          <!-- Glow effect on hover -->
          <div class="bar-glow"></div>
        </div>
        <span class="w-16 sm:w-20 md:w-24 text-[10px] sm:text-xs text-text-muted font-mono text-right group-hover:text-text-secondary transition-colors hidden sm:block">
          {tech.category}
        </span>
      </div>
    ))}
  </div>

  <!-- Bottom decoration with gradient -->
  <div class="absolute bottom-3 sm:bottom-4 left-3 sm:left-4 right-3 sm:right-4 h-px bg-gradient-to-r from-accent/20 via-gold/40 to-accent/20"></div>
</Card>

<style>
  .tech-stack-card {
    background: linear-gradient(135deg,
      rgba(28, 28, 28, 0.95) 0%,
      rgba(20, 20, 20, 0.98) 100%
    );
  }

  .progress-bar {
    animation: progressFill 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
    width: 0;
  }

  @keyframes progressFill {
    from {
      width: 0;
    }
  }

  .shimmer-effect {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transform: translateX(-100%);
    transition: transform 0.8s ease;
  }

  .tech-row:hover .shimmer-effect {
    transform: translateX(100%);
  }

  .bar-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    box-shadow: inset 0 0 20px var(--glow-color, rgba(255,255,255,0.1));
    border-radius: 9999px;
  }

  .tech-row:hover .bar-glow {
    opacity: 1;
  }

  .tech-row {
    transition: transform 0.2s ease;
  }

  .tech-row:hover {
    transform: translateX(4px);
  }

  .tech-row:hover .progress-bar {
    box-shadow: 0 0 20px var(--glow-color, rgba(255,255,255,0.2));
  }
</style>
