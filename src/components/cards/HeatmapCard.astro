---
import Card from '@components/shared/Card.astro';
import Mascot from '@components/decorative/Mascot.astro';
import SectionLabel from '@components/shared/SectionLabel.astro';

interface Props {
  stagger?: number;
}

const { stagger = 1 } = Astro.props;

// Generate mock heatmap data (7 cols x 4 rows = 28 cells)
const months = ['Nov', 'Dec', 'Jan', 'Feb'];
const generateIntensity = () => Math.floor(Math.random() * 5); // 0-4 intensity levels
const heatmapData = Array.from({ length: 28 }, () => generateIntensity());

const intensityColors = [
  'bg-[#2a2520]',      // 0 - lowest
  'bg-[#3d352a]',      // 1
  'bg-[#5a4d3a]',      // 2
  'bg-[#8b7a5a]',      // 3
  'bg-[#c4b89a]',      // 4 - highest (accent)
];

const intensityGlows = [
  '',
  '',
  '',
  'shadow-[0_0_8px_rgba(196,184,154,0.2)]',
  'shadow-[0_0_12px_rgba(196,184,154,0.4)]',
];
---

<Card colSpan={1} class="min-h-[260px]" stagger={stagger} glow>
  <div class="flex items-start justify-between mb-4">
    <SectionLabel>Parcels Registered</SectionLabel>
    <div class="flex items-center gap-2">
      <div class="glow-dot"></div>
      <span class="text-xs text-green font-mono">Live</span>
    </div>
  </div>

  <!-- Month labels -->
  <div class="flex justify-between mb-2 px-1">
    {months.map(month => (
      <span class="text-[10px] text-text-muted font-mono">{month}</span>
    ))}
  </div>

  <!-- Heatmap grid -->
  <div class="grid grid-cols-7 gap-1.5 mb-4">
    {heatmapData.map((intensity, index) => (
      <div
        class:list={[
          "w-full aspect-square rounded-sm transition-all duration-300 hover:scale-125 hover:z-10 cursor-pointer",
          intensityColors[intensity],
          intensityGlows[intensity],
          intensity === 4 && "heatmap-cell-active"
        ]}
        style={`animation-delay: ${index * 30}ms`}
        data-intensity={intensity}
      />
    ))}
  </div>

  <!-- Legend -->
  <div class="flex items-center justify-between mb-4">
    <span class="text-[10px] text-text-muted">Less</span>
    <div class="flex gap-1">
      {intensityColors.map((color, i) => (
        <div class:list={["w-3 h-3 rounded-sm", color]} />
      ))}
    </div>
    <span class="text-[10px] text-text-muted">More</span>
  </div>

  <!-- Mascot with speech bubble -->
  <div class="flex justify-end -mr-2 -mb-2">
    <Mascot
      size="sm"
      pose="pointing"
      speechBubble="Check our registry stats!"
    />
  </div>
</Card>

<style>
  [data-intensity] {
    animation: cellFadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes cellFadeIn {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
