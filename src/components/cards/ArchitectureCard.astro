---
import Card from '@components/shared/Card.astro';
import { Smartphone, Key, Settings, Database, Link } from 'lucide-astro';

interface Props {
  stagger?: number;
  compact?: boolean;
}

const { stagger = 1, compact = false } = Astro.props;

const layers = [
  {
    icon: Smartphone,
    name: 'Presentation Layer',
    components: ['Mobile', 'Web Portal', 'SMS', 'QR'],
    color: 'border-[#9a8a6a]'
  },
  {
    icon: Key,
    name: 'API & Auth Layer',
    components: ['Gateway', 'OAuth + DID', 'KYC'],
    color: 'border-[#8a7a5a]'
  },
  {
    icon: Settings,
    name: 'Business Logic',
    components: ['Registry', 'Transfer', 'Disputes'],
    color: 'border-[#7a6a4a]'
  },
  {
    icon: Database,
    name: 'Data Layer',
    components: ['PostGIS', 'Arweave', 'Redis', 'Kafka'],
    color: 'border-[#6a5a3a]'
  },
  {
    icon: Link,
    name: 'Blockchain Settlement',
    components: ['Blockchain', 'Merkle', 'Oracle', 'MultiSig'],
    color: 'border-[#5a4a2a]'
  }
];
---

<Card colSpan={2} href="/technology" class:list={["min-h-[280px] sm:min-h-[300px] md:min-h-[320px]", compact && "min-h-[220px] sm:min-h-[240px] md:min-h-[260px]"]} stagger={stagger}>
  <h3 class="heading-mono text-base sm:text-lg text-text-primary mb-3 sm:mb-4">System Architecture</h3>

  <div class="space-y-1.5 sm:space-y-2">
    {layers.map((layer, index) => (
      <div
        class:list={[
          "flex items-center gap-2 sm:gap-3 md:gap-4 p-2 sm:p-2.5 md:p-3 rounded-lg border bg-surface-hover/30 transition-all hover:bg-surface-hover",
          layer.color
        ]}
      >
        <div class="flex-shrink-0 w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8 rounded-md bg-surface border border-border flex items-center justify-center text-text-secondary">
          <layer.icon class="w-3 h-3 sm:w-3.5 sm:h-3.5 md:w-4 md:h-4" />
        </div>
        <div class="flex-1 min-w-0">
          <h4 class="text-xs sm:text-sm text-text-primary font-mono mb-0.5">{layer.name}</h4>
          <p class="text-[10px] sm:text-xs text-text-muted font-mono truncate">
            {layer.components.join(' · ')}
          </p>
        </div>
      </div>
    ))}
  </div>
</Card>
