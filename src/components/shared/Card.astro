---
interface Props {
  class?: string;
  colSpan?: 1 | 2 | 3;
  href?: string;
  external?: boolean;
  animate?: boolean;
  stagger?: number;
  glow?: boolean;
  accent?: boolean;
  spotlight?: boolean;
  tilt?: boolean;
  gradientBorder?: boolean;
  interactive?: boolean;
  label?: string;
}

const {
  class: className = '',
  colSpan = 1,
  href,
  external = false,
  animate = true,
  stagger = 0,
  glow = false,
  accent = false,
  spotlight = false,
  tilt = false,
  gradientBorder = false,
  interactive = true,
  label
} = Astro.props;

const Tag = href ? 'a' : 'div';
const colClass = colSpan === 1 ? 'col-span-1' : colSpan === 2 ? 'col-span-2' : 'col-span-3';
const staggerClass = stagger > 0 ? `stagger-${stagger}` : '';
---

<Tag
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  aria-label={label}
  class:list={[
    "card block",
    colClass,
    animate && "animate-fade-in",
    staggerClass,
    href && "cursor-pointer",
    glow && "card-glow",
    accent && "card-accent",
    spotlight && "card-spotlight",
    tilt && "card-tilt",
    gradientBorder && "card-gradient-border",
    interactive && "card-interactive",
    className
  ]}
  data-animate={animate ? '' : undefined}
  data-card
  data-tilt={tilt ? '' : undefined}
  tabindex={href ? undefined : (interactive ? 0 : undefined)}
  role={href ? undefined : (interactive ? "button" : undefined)}
>
  <slot />
  {external && (
    <div class="external-arrow" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 10L10 4M10 4H5M10 4V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  )}
</Tag>

<style>
  .card-interactive:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .card-tilt {
    transform-style: preserve-3d;
    perspective: 1000px;
    transition: transform 0.1s ease-out;
  }
</style>

<script>
  // Add mouse tracking for glow effect
  document.querySelectorAll('[data-card]').forEach(function(card) {
    var el = card;

    // Mouse tracking for spotlight/glow effect
    el.addEventListener('mousemove', function(e) {
      var rect = el.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      el.style.setProperty('--mouse-x', x + 'px');
      el.style.setProperty('--mouse-y', y + 'px');
    });

    // Tilt effect
    if (el.hasAttribute('data-tilt')) {
      el.addEventListener('mousemove', function(e) {
        var rect = el.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var centerX = rect.width / 2;
        var centerY = rect.height / 2;

        var rotateX = ((y - centerY) / centerY) * -5;
        var rotateY = ((x - centerX) / centerX) * 5;

        el.style.transform = 'perspective(1000px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) translateZ(10px)';
      });

      el.addEventListener('mouseleave', function() {
        el.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) translateZ(0)';
      });
    }

    // Keyboard support for interactive cards
    if (el.getAttribute('role') === 'button') {
      el.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          el.click();
        }
      });
    }
  });
</script>
