---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={["grid-background absolute inset-0 overflow-hidden pointer-events-none", className]}>
  <svg
    width="100%"
    height="100%"
    xmlns="http://www.w3.org/2000/svg"
    class="opacity-30"
  >
    <defs>
      <pattern id="dot-pattern" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.5" fill="rgba(232, 224, 208, 0.15)" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dot-pattern)" />
  </svg>
</div>
