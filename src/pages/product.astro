---
import BaseLayout from '@layouts/BaseLayout.astro';
import BentoGrid from '@components/shared/BentoGrid.astro';
import Card from '@components/shared/Card.astro';
import FeatureCard from '@components/cards/FeatureCard.astro';
import CTACard from '@components/cards/CTACard.astro';
import TopographyCard from '@components/cards/TopographyCard.astro';
import Mascot from '@components/decorative/Mascot.astro';
import {
  Lock,
  QrCode,
  Users,
  Scale,
  Map,
  WifiOff,
  LayoutDashboard,
  Building2,
  Shield,
  Smartphone,
  Globe,
  FileCheck,
  Clock,
  CheckCircle,
  AlertTriangle,
  ArrowRight
} from 'lucide-astro';
---

<BaseLayout
  title="Product — TerraChain"
  description="The complete land registry stack. Immutable registration, universal verification, and secure transfers built on Blockchain."
>
  <div class="pt-24 pb-8">
    <BentoGrid>
      <!-- Hero Card -->
      <Card colSpan={2} class="min-h-[240px] overflow-hidden" stagger={1} glow accent>
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-2 h-2 rounded-full bg-green animate-pulse"></div>
            <span class="text-xs text-green font-mono uppercase tracking-wider">Production Ready</span>
          </div>
          <h1 class="text-3xl md:text-4xl mb-4">The Complete Land Registry Stack</h1>
          <p class="text-text-secondary leading-relaxed max-w-2xl mb-6">
            An end-to-end solution for governments and institutions to digitize land records,
            enable secure transfers, and provide universal verification — all backed by
            cryptographic proof on Blockchain.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/technology" class="btn btn-primary group">
              View Architecture
              <ArrowRight class="w-4 h-4 transition-transform group-hover:translate-x-1" />
            </a>
            <a href="mailto:hello@terrachain.xyz" class="btn btn-secondary">
              Request Demo
            </a>
          </div>
        </div>
      </Card>

      <TopographyCard label="PRODUCT" stagger={2} />

      <!-- Key Metrics -->
      <Card colSpan={3} class="min-h-[120px]" stagger={3} glow>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {[
            { value: '<1s', label: 'Transaction Finality', icon: Clock },
            { value: '$0.02', label: 'Cost per Registration', icon: FileCheck },
            { value: '99.9%', label: 'Uptime SLA', icon: CheckCircle },
            { value: '50K+', label: 'Parcels Registered', icon: Map },
          ].map((metric, i) => (
            <div class="text-center group" style={`--delay: ${i * 100}ms`}>
              <div class="flex items-center justify-center gap-2 mb-2">
                <metric.icon class="w-4 h-4 text-text-muted group-hover:text-accent transition-colors" />
                <span class="stat-number text-2xl">{metric.value}</span>
              </div>
              <p class="text-xs text-text-muted font-mono">{metric.label}</p>
            </div>
          ))}
        </div>
      </Card>

      <!-- Feature: Immutable Registration -->
      <FeatureCard
        icon={Lock}
        title="Immutable Registration"
        description="Every land parcel is registered with a unique cryptographic hash. Once recorded, the data cannot be altered, deleted, or corrupted — even by system administrators."
        stagger={4}
      />

      <!-- Feature: Universal Verification -->
      <FeatureCard
        icon={QrCode}
        title="Universal Verification"
        description="Verify any land title instantly via QR code scan, SMS query, or API call. No specialized software required — works on any device with internet access."
        stagger={5}
      />

      <!-- Feature: Multi-Sig Transfer -->
      <Card colSpan={2} class="min-h-[300px]" stagger={6} glow accent>
        <div class="flex items-start gap-4 mb-6">
          <div class="icon-container text-accent">
            <Users class="w-5 h-5" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary mb-2">Multi-Signature Transfer</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Land transfers require approval from multiple parties: buyer, seller, witness, and
              government authority. Funds are held in escrow until all signatures are collected.
            </p>
          </div>
        </div>

        <!-- Transfer flow diagram -->
        <div class="relative p-6 bg-surface-hover rounded-lg">
          <div class="flex items-center justify-between gap-2">
            {[
              { label: 'Seller', abbr: 'S', status: 'completed' },
              { label: 'Buyer', abbr: 'B', status: 'completed' },
              { label: 'Witness', abbr: 'W', status: 'pending' },
              { label: 'Government', abbr: 'G', status: 'waiting' },
            ].map((party, i) => (
              <div class="text-center flex-1">
                <div class:list={[
                  "w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-2 transition-all duration-300",
                  party.status === 'completed' && "bg-green/20 border-2 border-green text-green",
                  party.status === 'pending' && "bg-accent/20 border-2 border-accent text-accent animate-pulse",
                  party.status === 'waiting' && "bg-surface border-2 border-border text-text-muted"
                ]}>
                  {party.status === 'completed' ? (
                    <CheckCircle class="w-5 h-5" />
                  ) : (
                    <span class="text-sm font-mono font-bold">{party.abbr}</span>
                  )}
                </div>
                <span class="text-xs text-text-muted font-mono">{party.label}</span>
                <div class:list={[
                  "text-[10px] mt-1 font-mono",
                  party.status === 'completed' && "text-green",
                  party.status === 'pending' && "text-accent",
                  party.status === 'waiting' && "text-text-muted"
                ]}>
                  {party.status === 'completed' && 'Signed'}
                  {party.status === 'pending' && 'Awaiting'}
                  {party.status === 'waiting' && 'Pending'}
                </div>
                {i < 3 && (
                  <div class="absolute top-1/2 -translate-y-1/2 h-px bg-gradient-to-r from-border to-transparent" style={`left: ${(i + 1) * 25}%; width: 20%;`}></div>
                )}
              </div>
            ))}
          </div>

          <!-- Progress indicator -->
          <div class="mt-4 pt-4 border-t border-border">
            <div class="flex items-center justify-between text-xs mb-2">
              <span class="text-text-muted font-mono">Transfer Progress</span>
              <span class="text-accent font-mono">2 of 4 signatures</span>
            </div>
            <div class="h-2 bg-surface rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-green to-accent rounded-full transition-all duration-1000" style="width: 50%"></div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Feature: Dispute Resolution -->
      <FeatureCard
        icon={Scale}
        title="Dispute Resolution"
        description="Built-in workflow for handling boundary disputes and ownership claims. All evidence is timestamped and immutable, creating a clear audit trail for arbitration."
        stagger={7}
      />

      <!-- Feature: GeoSpatial Engine -->
      <Card colSpan={2} class="min-h-[320px]" stagger={8} glow>
        <div class="flex items-start gap-4 mb-4">
          <div class="icon-container text-accent">
            <Map class="w-5 h-5" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary mb-2">Geospatial Engine</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              PostGIS-powered boundary detection with sub-meter accuracy. Automatic overlap detection
              prevents double-registration and boundary conflicts.
            </p>
          </div>
        </div>

        <!-- Map mockup with enhanced visuals -->
        <div class="relative h-48 bg-surface-hover rounded-lg overflow-hidden">
          <svg viewBox="0 0 400 200" class="w-full h-full" preserveAspectRatio="xMidYMid slice">
            <defs>
              <linearGradient id="parcelGreen" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="rgba(124, 154, 110, 0.2)" />
                <stop offset="100%" stop-color="rgba(124, 154, 110, 0.05)" />
              </linearGradient>
              <linearGradient id="parcelGold" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="rgba(196, 184, 154, 0.2)" />
                <stop offset="100%" stop-color="rgba(196, 184, 154, 0.05)" />
              </linearGradient>
              <linearGradient id="parcelRed" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="rgba(154, 110, 110, 0.3)" />
                <stop offset="100%" stop-color="rgba(154, 110, 110, 0.1)" />
              </linearGradient>
            </defs>

            <!-- Grid lines -->
            {Array.from({ length: 20 }).map((_, i) => (
              <line x1={i * 20} y1="0" x2={i * 20} y2="200" stroke="rgba(42, 42, 42, 0.6)" stroke-width="1" />
            ))}
            {Array.from({ length: 10 }).map((_, i) => (
              <line x1="0" y1={i * 20} x2="400" y2={i * 20} stroke="rgba(42, 42, 42, 0.6)" stroke-width="1" />
            ))}

            <!-- Land parcels with animations -->
            <g class="parcel" style="--delay: 0.2s">
              <rect x="40" y="30" width="90" height="60" stroke="#7c9a6e" stroke-width="2" fill="url(#parcelGreen)" rx="3" class="hover:stroke-green transition-colors" />
              <text x="85" y="65" font-family="IBM Plex Mono" font-size="10" fill="#7c9a6e" text-anchor="middle">P-001</text>
              <circle cx="50" cy="40" r="4" fill="#7c9a6e" class="animate-pulse" />
            </g>

            <g class="parcel" style="--delay: 0.4s">
              <rect x="150" y="40" width="110" height="80" stroke="#c4b89a" stroke-width="2" fill="url(#parcelGold)" rx="3" />
              <text x="205" y="85" font-family="IBM Plex Mono" font-size="10" fill="#c4b89a" text-anchor="middle">P-002</text>
              <circle cx="160" cy="50" r="4" fill="#c4b89a" class="animate-pulse" />
            </g>

            <g class="parcel" style="--delay: 0.6s">
              <rect x="280" y="25" width="100" height="70" stroke="#7c9a6e" stroke-width="2" fill="url(#parcelGreen)" rx="3" />
              <text x="330" y="65" font-family="IBM Plex Mono" font-size="10" fill="#7c9a6e" text-anchor="middle">P-003</text>
              <circle cx="290" cy="35" r="4" fill="#7c9a6e" class="animate-pulse" />
            </g>

            <g class="parcel" style="--delay: 0.8s">
              <rect x="60" y="110" width="140" height="60" stroke="#c4b89a" stroke-width="2" fill="url(#parcelGold)" rx="3" />
              <text x="130" y="145" font-family="IBM Plex Mono" font-size="10" fill="#c4b89a" text-anchor="middle">P-004</text>
              <circle cx="70" cy="120" r="4" fill="#c4b89a" class="animate-pulse" />
            </g>

            <!-- Disputed parcel with warning -->
            <g class="parcel disputed" style="--delay: 1s">
              <rect x="220" y="130" width="90" height="55" stroke="#9a6e6e" stroke-width="2" fill="url(#parcelRed)" rx="3" class="animate-pulse" />
              <text x="265" y="160" font-family="IBM Plex Mono" font-size="9" fill="#9a6e6e" text-anchor="middle">DISPUTE</text>
              <circle cx="265" cy="140" r="8" fill="none" stroke="#9a6e6e" stroke-width="1.5" class="animate-ping" />
              <text x="265" y="143" font-family="IBM Plex Mono" font-size="10" fill="#9a6e6e" text-anchor="middle">!</text>
            </g>
          </svg>

          <!-- Legend -->
          <div class="absolute bottom-3 left-3 flex gap-4 text-[10px] font-mono">
            <div class="flex items-center gap-1">
              <div class="w-3 h-3 rounded-sm bg-green/30 border border-green"></div>
              <span class="text-text-muted">Verified</span>
            </div>
            <div class="flex items-center gap-1">
              <div class="w-3 h-3 rounded-sm bg-accent/30 border border-accent"></div>
              <span class="text-text-muted">Pending</span>
            </div>
            <div class="flex items-center gap-1">
              <div class="w-3 h-3 rounded-sm bg-red/30 border border-red"></div>
              <span class="text-text-muted">Disputed</span>
            </div>
          </div>
        </div>
      </Card>

      <!-- Mobile & Offline Features -->
      <Card colSpan={1} class="min-h-[280px]" stagger={9} glow>
        <div class="icon-container text-accent mb-4">
          <Smartphone class="w-5 h-5" />
        </div>
        <h3 class="heading-mono text-base text-text-primary mb-3">Mobile-First Design</h3>

        <div class="space-y-3">
          {[
            { icon: WifiOff, label: 'Offline-capable surveying', desc: 'Works without internet' },
            { icon: Map, label: 'GPS boundary capture', desc: 'Sub-meter accuracy' },
            { icon: FileCheck, label: 'Photo documentation', desc: 'Evidence collection' },
            { icon: Users, label: 'Digital signatures', desc: 'Biometric support' },
          ].map((feature, i) => (
            <div class="flex items-start gap-3 p-2 rounded-lg hover:bg-surface-hover transition-colors group">
              <feature.icon class="w-4 h-4 text-text-muted group-hover:text-accent transition-colors flex-shrink-0 mt-0.5" />
              <div>
                <p class="text-sm text-text-primary">{feature.label}</p>
                <p class="text-xs text-text-muted">{feature.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </Card>

      <!-- Admin Dashboard -->
      <FeatureCard
        icon={LayoutDashboard}
        title="Admin Dashboard"
        description="Web-based portal for government officials to review registrations, approve transfers, and monitor system health with real-time analytics."
        colSpan={1}
        stagger={10}
      />

      <!-- Integration Card -->
      <Card colSpan={1} class="min-h-[280px]" stagger={11} glow>
        <div class="icon-container text-accent mb-4">
          <Globe class="w-5 h-5" />
        </div>
        <h3 class="heading-mono text-base text-text-primary mb-3">Integration Ready</h3>

        <div class="space-y-3">
          {[
            { label: 'Banking APIs', desc: 'Mortgage verification' },
            { label: 'Government Systems', desc: 'LADM & ISO 19152' },
            { label: 'GIS Platforms', desc: 'QGIS, ArcGIS export' },
            { label: 'Tax Systems', desc: 'Property tax sync' },
          ].map((item, i) => (
            <div class="flex items-center justify-between p-2 rounded-lg bg-surface-hover/50 group hover:bg-surface-hover transition-colors">
              <span class="text-sm text-text-primary">{item.label}</span>
              <span class="text-xs text-text-muted group-hover:text-accent transition-colors">{item.desc}</span>
            </div>
          ))}
        </div>
      </Card>

      <!-- Security Model -->
      <Card colSpan={2} class="min-h-[240px]" stagger={12} glow accent>
        <div class="flex items-start gap-4 mb-6">
          <div class="icon-container text-accent">
            <Shield class="w-5 h-5" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary mb-2">Enterprise Security</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Defense in depth with multiple security layers. SOC 2 Type II certified.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { label: 'Data at Rest', value: 'AES-256', color: 'green' },
            { label: 'Data in Transit', value: 'TLS 1.3', color: 'green' },
            { label: 'Hash Algorithm', value: 'SHA-256', color: 'accent' },
            { label: 'Signatures', value: 'Ed25519', color: 'accent' },
          ].map((item, i) => (
            <div class="p-4 bg-surface-hover rounded-lg text-center group hover:bg-surface transition-colors" style={`--delay: ${i * 100}ms`}>
              <p class:list={[
                "font-mono text-lg mb-1 transition-all group-hover:scale-110",
                item.color === 'green' ? "text-green" : "text-accent"
              ]}>{item.value}</p>
              <p class="text-text-muted text-xs">{item.label}</p>
            </div>
          ))}
        </div>

        <!-- Compliance badges -->
        <div class="mt-6 pt-4 border-t border-border flex flex-wrap gap-3">
          {['SOC 2 Type II', 'GDPR Compliant', 'ISO 27001', 'LADM Standard'].map(badge => (
            <span class="px-3 py-1 text-xs font-mono bg-surface-hover rounded-full text-text-muted border border-border">
              {badge}
            </span>
          ))}
        </div>
      </Card>

      <!-- Pricing Teaser -->
      <Card colSpan={1} class="min-h-[240px]" stagger={13} glow>
        <h3 class="heading-mono text-base text-text-primary mb-4">Simple Pricing</h3>

        <div class="space-y-4">
          <div class="p-4 bg-surface-hover rounded-lg">
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-2xl text-accent font-mono">$0.02</span>
              <span class="text-xs text-text-muted">/ registration</span>
            </div>
            <p class="text-xs text-text-muted">No hidden fees. Pay only for what you use.</p>
          </div>

          <div class="space-y-2">
            {['Unlimited verifications', 'API access included', '24/7 support', 'Custom SLA available'].map(feature => (
              <div class="flex items-center gap-2 text-sm text-text-secondary">
                <CheckCircle class="w-4 h-4 text-green" />
                <span>{feature}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-4 flex justify-end">
          <Mascot size="sm" pose="pointing" />
        </div>
      </Card>

      <!-- CTA -->
      <CTACard stagger={14} />
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .parcel {
    opacity: 0;
    animation: parcelFadeIn 0.5s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes parcelFadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
