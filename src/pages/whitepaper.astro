---
import BaseLayout from '@layouts/BaseLayout.astro';
import BentoGrid from '@components/shared/BentoGrid.astro';
import Card from '@components/shared/Card.astro';
import TopographyCard from '@components/cards/TopographyCard.astro';
import Mascot from '@components/decorative/Mascot.astro';
import { FileText, Download, BookOpen, Layers, Shield, Globe, Cpu, Users, TrendingUp, ArrowRight, Check, ExternalLink, Clock, Calendar, Hash } from 'lucide-astro';
---

<BaseLayout
  title="Whitepaper — TerraChain"
  description="The TerraChain Whitepaper: A comprehensive technical overview of blockchain-based land title registry."
>
  <div class="pt-24 pb-8">
    <BentoGrid>
      <!-- Hero Section -->
      <Card colSpan={2} class="min-h-[320px] relative overflow-hidden" stagger={1} glow>
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-radial from-accent/10 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-radial from-gold/10 to-transparent rounded-full blur-2xl"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <FileText class="w-5 h-5 text-accent" />
            <span class="text-xs text-accent font-mono uppercase tracking-wider">Technical Whitepaper</span>
          </div>

          <h1 class="text-3xl md:text-4xl text-text-primary mb-4 leading-tight">
            TerraChain:<br/>
            <span class="text-gradient-gold">Immutable Land Rights</span><br/>
            on Blockchain
          </h1>

          <p class="text-text-secondary max-w-lg mb-6">
            A comprehensive technical specification for building a scalable, decentralized land title registry that serves 1 billion+ people without secure property rights.
          </p>

          <div class="flex flex-wrap gap-3 mb-6">
            <span class="px-3 py-1.5 text-xs font-mono bg-surface-hover border border-border rounded-full text-text-secondary flex items-center gap-2">
              <Calendar class="w-3 h-3" /> v2.1 — January 2025
            </span>
            <span class="px-3 py-1.5 text-xs font-mono bg-surface-hover border border-border rounded-full text-text-secondary flex items-center gap-2">
              <Clock class="w-3 h-3" /> 45 min read
            </span>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="/whitepaper.pdf" class="btn btn-primary inline-flex items-center gap-2 no-underline group">
              <Download class="w-4 h-4" />
              <span>Download PDF</span>
            </a>
            <a href="#abstract" class="btn btn-secondary inline-flex items-center gap-2 no-underline">
              <BookOpen class="w-4 h-4" />
              <span>Read Online</span>
            </a>
          </div>
        </div>
      </Card>

      <!-- Document Info -->
      <Card colSpan={1} class="min-h-[320px]" stagger={2}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Document Info</h3>

        <div class="space-y-4">
          <div class="info-item">
            <span class="text-xs text-text-muted block mb-1">Version</span>
            <span class="text-sm text-text-primary font-mono">2.1.0</span>
          </div>
          <div class="info-item">
            <span class="text-xs text-text-muted block mb-1">Last Updated</span>
            <span class="text-sm text-text-primary font-mono">January 15, 2025</span>
          </div>
          <div class="info-item">
            <span class="text-xs text-text-muted block mb-1">Authors</span>
            <span class="text-sm text-text-secondary">Alex Chen, Maria Santos, Sarah Kim</span>
          </div>
          <div class="info-item">
            <span class="text-xs text-text-muted block mb-1">Hash (SHA-256)</span>
            <span class="text-xs text-accent font-mono break-all">7f83b1657ff1fc53b92dc18148a1d65dfc2d4b1fa3d677284addd200126d9069</span>
          </div>
          <div class="info-item">
            <span class="text-xs text-text-muted block mb-1">License</span>
            <span class="text-sm text-text-primary font-mono">CC BY 4.0</span>
          </div>
        </div>

        <div class="mt-6 pt-4 border-t border-border">
          <a href="https://arxiv.org/abs/xxxx.xxxxx" target="_blank" rel="noopener" class="text-sm text-accent hover:text-accent/80 flex items-center gap-2 no-underline">
            <ExternalLink class="w-4 h-4" />
            <span>View on arXiv</span>
          </a>
        </div>
      </Card>

      <!-- Table of Contents -->
      <Card colSpan={1} class="min-h-[400px]" stagger={3}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Table of Contents</h3>

        <nav class="space-y-1">
          {[
            { num: '01', title: 'Abstract', id: 'abstract' },
            { num: '02', title: 'Problem Statement', id: 'problem' },
            { num: '03', title: 'Solution Architecture', id: 'architecture' },
            { num: '04', title: 'Consensus Mechanism', id: 'consensus' },
            { num: '05', title: 'Smart Contracts', id: 'contracts' },
            { num: '06', title: 'Data Model', id: 'data-model' },
            { num: '07', title: 'Geospatial Engine', id: 'geospatial' },
            { num: '08', title: 'Security Model', id: 'security' },
            { num: '09', title: 'Governance', id: 'governance' },
            { num: '10', title: 'Tokenomics', id: 'tokenomics' },
            { num: '11', title: 'Roadmap', id: 'roadmap' },
            { num: '12', title: 'References', id: 'references' },
          ].map((item, i) => (
            <a href={`#${item.id}`} class="toc-item flex items-center gap-3 p-2 rounded-lg hover:bg-surface-hover transition-all no-underline group" style={`--delay: ${i * 0.05}s`}>
              <span class="text-xs font-mono text-accent/50 group-hover:text-accent transition-colors">{item.num}</span>
              <span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">{item.title}</span>
            </a>
          ))}
        </nav>
      </Card>

      <!-- Abstract Section -->
      <Card colSpan={2} class="min-h-[300px]" stagger={4} id="abstract">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <BookOpen class="w-5 h-5 text-accent" />
          </div>
          <div>
            <span class="text-xs text-accent font-mono">01</span>
            <h2 class="text-xl text-text-primary">Abstract</h2>
          </div>
        </div>

        <div class="prose prose-invert max-w-none">
          <p class="text-text-secondary leading-relaxed mb-4">
            We present TerraChain, a decentralized land title registry built on the Blockchain. Our system addresses the critical challenge of insecure land rights affecting over 1 billion people globally, with an estimated $9.3 trillion in assets held as "dead capital."
          </p>
          <p class="text-text-secondary leading-relaxed mb-4">
            TerraChain introduces a novel architecture combining <span class="text-text-primary">on-chain ownership records</span> with <span class="text-text-primary">off-chain geospatial validation</span>, enabling sub-second transaction finality at costs below $0.01 per registration. The system employs multi-signature governance, merkle tree verification, and integration with decentralized storage networks for permanent document archival.
          </p>
          <p class="text-text-secondary leading-relaxed">
            Our pilot deployments in Rwanda and the Philippines have demonstrated 99.9% uptime, 15-second average registration time, and zero successful fraud attempts across 50,000+ registered parcels.
          </p>
        </div>
      </Card>

      <!-- Key Innovations -->
      <Card colSpan={3} class="min-h-[250px]" stagger={5}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Layers class="w-5 h-5 text-gold" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary">Key Innovations</h3>
            <p class="text-xs text-text-muted">What makes TerraChain unique</p>
          </div>
        </div>

        <div class="grid grid-cols-4 gap-4">
          <div class="innovation-card p-4 bg-surface-hover rounded-lg border border-border hover:border-border-hover transition-all group" style="--delay: 0s">
            <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/30 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <Layers class="w-5 h-5 text-accent" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Hybrid Architecture</h4>
            <p class="text-xs text-text-muted leading-relaxed">On-chain ownership + off-chain spatial data for optimal cost/performance</p>
          </div>
          <div class="innovation-card p-4 bg-surface-hover rounded-lg border border-border hover:border-border-hover transition-all group" style="--delay: 0.1s">
            <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/30 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <Shield class="w-5 h-5 text-gold" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Multi-Sig Governance</h4>
            <p class="text-xs text-text-muted leading-relaxed">Government, community, and protocol validators for fraud prevention</p>
          </div>
          <div class="innovation-card p-4 bg-surface-hover rounded-lg border border-border hover:border-border-hover transition-all group" style="--delay: 0.2s">
            <div class="w-10 h-10 rounded-lg bg-green/10 border border-green/30 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <Globe class="w-5 h-5 text-green" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Mobile-First Design</h4>
            <p class="text-xs text-text-muted leading-relaxed">Works on 2G networks with SMS fallback for rural areas</p>
          </div>
          <div class="innovation-card p-4 bg-surface-hover rounded-lg border border-border hover:border-border-hover transition-all group" style="--delay: 0.3s">
            <div class="w-10 h-10 rounded-lg bg-copper/10 border border-copper/30 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform">
              <Cpu class="w-5 h-5 text-copper" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Proof of Location</h4>
            <p class="text-xs text-text-muted leading-relaxed">Novel consensus for geospatial claim verification</p>
          </div>
        </div>
      </Card>

      <!-- Problem Statement -->
      <Card colSpan={2} class="min-h-[280px]" stagger={6} id="problem">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Globe class="w-5 h-5 text-gold" />
          </div>
          <div>
            <span class="text-xs text-gold font-mono">02</span>
            <h2 class="text-xl text-text-primary">Problem Statement</h2>
          </div>
        </div>

        <div class="space-y-4">
          <p class="text-text-secondary leading-relaxed">
            Traditional land registries suffer from three fundamental challenges:
          </p>

          <div class="space-y-3">
            {[
              { title: 'Centralization Risk', desc: 'Single points of failure enable corruption, data loss, and political manipulation' },
              { title: 'Accessibility Gap', desc: 'Physical registries exclude rural populations and require expensive intermediaries' },
              { title: 'Verification Cost', desc: 'Title searches and dispute resolution can take years and cost thousands of dollars' },
            ].map((problem, i) => (
              <div class="problem-item flex items-start gap-3 p-3 bg-surface-hover rounded-lg" style={`--delay: ${i * 0.1}s`}>
                <div class="w-6 h-6 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-xs font-mono text-accent">{i + 1}</span>
                </div>
                <div>
                  <h4 class="text-sm text-text-primary font-mono mb-1">{problem.title}</h4>
                  <p class="text-xs text-text-muted">{problem.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Card>

      <!-- Topography -->
      <TopographyCard label="WHITEPAPER" stagger={7} />

      <!-- Architecture Overview -->
      <Card colSpan={3} class="min-h-[350px]" stagger={8} id="architecture">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green/20 to-transparent border border-green/30 flex items-center justify-center">
            <Layers class="w-5 h-5 text-green" />
          </div>
          <div>
            <span class="text-xs text-green font-mono">03</span>
            <h2 class="text-xl text-text-primary">Solution Architecture</h2>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-6">
          <div class="arch-component p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-accent font-mono mb-3">On-Chain Layer</h4>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Ownership NFTs (Metaplex)</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Transfer escrow contracts</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Multi-sig governance</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Merkle root anchoring</li>
            </ul>
          </div>

          <div class="arch-component p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-gold font-mono mb-3">Off-Chain Services</h4>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> PostGIS spatial validation</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> KYC/AML verification</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Document indexing</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Notification service</li>
            </ul>
          </div>

          <div class="arch-component p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-green font-mono mb-3">Storage Layer</h4>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Arweave (documents)</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> IPFS (media)</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> PostgreSQL (metadata)</li>
              <li class="flex items-start gap-2"><Check class="w-3 h-3 text-green mt-0.5 flex-shrink-0" /> Redis (caching)</li>
            </ul>
          </div>
        </div>

        <div class="mt-6 p-4 bg-surface rounded-lg border border-border">
          <p class="text-xs text-text-muted text-center">
            See Section 3.2 for detailed component interaction diagrams and API specifications
          </p>
        </div>
      </Card>

      <!-- Stats Section -->
      <Card colSpan={1} class="min-h-[200px]" stagger={9}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Benchmark Results</h3>

        <div class="space-y-4">
          <div class="benchmark">
            <div class="flex justify-between mb-1">
              <span class="text-xs text-text-muted">Registration Time</span>
              <span class="text-sm text-accent font-mono">15s</span>
            </div>
            <div class="h-1.5 bg-surface rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-accent to-accent/50 rounded-full w-[95%]"></div>
            </div>
          </div>

          <div class="benchmark">
            <div class="flex justify-between mb-1">
              <span class="text-xs text-text-muted">Query Latency</span>
              <span class="text-sm text-gold font-mono">&lt;50ms</span>
            </div>
            <div class="h-1.5 bg-surface rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-gold to-gold/50 rounded-full w-[98%]"></div>
            </div>
          </div>

          <div class="benchmark">
            <div class="flex justify-between mb-1">
              <span class="text-xs text-text-muted">Cost per Tx</span>
              <span class="text-sm text-green font-mono">$0.008</span>
            </div>
            <div class="h-1.5 bg-surface rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-green to-green/50 rounded-full w-[99%]"></div>
            </div>
          </div>

          <div class="benchmark">
            <div class="flex justify-between mb-1">
              <span class="text-xs text-text-muted">Uptime</span>
              <span class="text-sm text-accent font-mono">99.97%</span>
            </div>
            <div class="h-1.5 bg-surface rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-accent to-green rounded-full w-[99.97%]"></div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Additional Sections Preview -->
      <Card colSpan={2} class="min-h-[200px]" stagger={10}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Additional Sections</h3>

        <div class="grid grid-cols-2 gap-3">
          {[
            { num: '04', title: 'Consensus Mechanism', desc: 'Proof of Location validation' },
            { num: '05', title: 'Smart Contracts', desc: 'Anchor program specifications' },
            { num: '06', title: 'Data Model', desc: 'Parcel, owner, and transfer schemas' },
            { num: '07', title: 'Geospatial Engine', desc: 'PostGIS integration details' },
            { num: '08', title: 'Security Model', desc: 'Threat analysis & mitigations' },
            { num: '09', title: 'Governance', desc: 'Multi-sig & DAO structure' },
          ].map((section, i) => (
            <a href={`#${section.title.toLowerCase().replace(' ', '-')}`} class="section-preview flex items-center gap-3 p-3 bg-surface-hover rounded-lg hover:bg-surface border border-transparent hover:border-border transition-all no-underline group" style={`--delay: ${i * 0.05}s`}>
              <span class="text-xs font-mono text-accent/50 group-hover:text-accent transition-colors">{section.num}</span>
              <div>
                <p class="text-sm text-text-primary">{section.title}</p>
                <p class="text-xs text-text-muted">{section.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </Card>

      <!-- Download CTA -->
      <Card colSpan={2} class="min-h-[180px] relative overflow-hidden group" stagger={11} glow accent>
        <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative z-10 flex items-center justify-between">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <FileText class="w-5 h-5 text-accent" />
              <span class="text-xs text-accent font-mono uppercase tracking-wider">Full Document</span>
            </div>
            <h3 class="text-xl text-text-primary mb-2">Download the Complete Whitepaper</h3>
            <p class="text-sm text-text-secondary max-w-md mb-4">
              45 pages covering architecture, security, governance, tokenomics, and roadmap in detail.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/whitepaper.pdf" class="btn btn-primary inline-flex items-center gap-2 no-underline group/btn">
                <Download class="w-4 h-4" />
                <span>Download PDF (2.4 MB)</span>
              </a>
              <a href="/whitepaper-lite.pdf" class="btn btn-secondary inline-flex items-center gap-2 no-underline">
                <FileText class="w-4 h-4" />
                <span>Executive Summary</span>
              </a>
            </div>
          </div>

          <div class="hidden md:block">
            <Mascot size="lg" pose="pointing" />
          </div>
        </div>
      </Card>

      <!-- Translations -->
      <Card colSpan={1} class="min-h-[180px]" stagger={12}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Translations</h3>

        <div class="space-y-2">
          {[
            { lang: 'English', code: 'EN', status: 'Complete' },
            { lang: 'Spanish', code: 'ES', status: 'Complete' },
            { lang: 'French', code: 'FR', status: 'Complete' },
            { lang: 'Swahili', code: 'SW', status: 'In Progress' },
            { lang: 'Indonesian', code: 'ID', status: 'Planned' },
          ].map((translation, i) => (
            <div class="translation-item flex items-center justify-between p-2 rounded-lg hover:bg-surface-hover transition-all" style={`--delay: ${i * 0.05}s`}>
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono text-accent">{translation.code}</span>
                <span class="text-sm text-text-secondary">{translation.lang}</span>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded-full ${translation.status === 'Complete' ? 'bg-green/10 text-green' : translation.status === 'In Progress' ? 'bg-gold/10 text-gold' : 'bg-surface text-text-muted'}`}>
                {translation.status}
              </span>
            </div>
          ))}
        </div>
      </Card>
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .text-gradient-gold {
    background: linear-gradient(135deg, var(--color-gold), var(--color-amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-copper {
    color: var(--color-copper);
  }

  .toc-item {
    animation: slideInLeft 0.3s ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  .innovation-card {
    animation: fadeInUp 0.4s ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  .problem-item {
    animation: fadeInUp 0.4s ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  .section-preview {
    animation: fadeIn 0.3s ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  .translation-item {
    animation: slideInLeft 0.3s ease-out forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .arch-component {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
  }

  .arch-component:nth-child(1) { animation-delay: 0.1s; }
  .arch-component:nth-child(2) { animation-delay: 0.2s; }
  .arch-component:nth-child(3) { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .toc-item,
    .innovation-card,
    .problem-item,
    .section-preview,
    .translation-item,
    .arch-component {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
