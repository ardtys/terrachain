---
import BaseLayout from '@layouts/BaseLayout.astro';
import BentoGrid from '@components/shared/BentoGrid.astro';
import Card from '@components/shared/Card.astro';
import TopographyCard from '@components/cards/TopographyCard.astro';
import Mascot from '@components/decorative/Mascot.astro';
import { MapPin, Users, Clock, TrendingUp, ArrowRight, ArrowLeft, Check, Globe, Building, Shield, FileText, Quote, Calendar, Target, Zap, Award, Download, ChevronRight, BarChart3, Landmark, Wheat, Sun, Compass } from 'lucide-astro';
---

<BaseLayout
  title="India Case Study — TerraChain"
  description="Partnering with Rajasthan's state government to modernize land records across India's largest state with blockchain technology."
>
  <div class="pt-24 pb-8">
    <BentoGrid>
      <!-- Back Navigation -->
      <Card colSpan={3} class="min-h-[60px] py-3" stagger={0}>
        <a href="/case-studies" class="inline-flex items-center gap-2 text-text-muted hover:text-accent transition-colors no-underline">
          <ArrowLeft class="w-4 h-4" />
          <span class="text-sm">Back to Case Studies</span>
        </a>
      </Card>

      <!-- Hero Section -->
      <Card colSpan={2} class="min-h-[350px] relative overflow-hidden" stagger={1} glow>
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-radial from-accent/10 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-radial from-gold/10 to-transparent rounded-full blur-2xl"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <MapPin class="w-5 h-5 text-accent" />
            <span class="text-xs text-accent font-mono uppercase tracking-wider">India • Rajasthan State</span>
          </div>

          <h1 class="text-3xl md:text-4xl text-text-primary mb-4 leading-tight">
            Rajasthan Digital<br/>
            <span class="text-gradient-gold">Land Initiative</span>
          </h1>

          <p class="text-text-secondary max-w-lg mb-6">
            Partnering with Rajasthan's state government to modernize land records across India's largest state, bringing blockchain-secured titles to millions of rural landowners in the Thar Desert region.
          </p>

          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 text-xs font-mono bg-accent/10 border border-accent/30 rounded-full text-accent flex items-center gap-2">
              <Clock class="w-3 h-3" /> Planning Phase
            </span>
            <span class="px-3 py-1.5 text-xs font-mono bg-surface-hover border border-border rounded-full text-text-secondary flex items-center gap-2">
              <Calendar class="w-3 h-3" /> Pilot Q2 2025
            </span>
          </div>
        </div>
      </Card>

      <!-- Key Metrics -->
      <Card colSpan={1} class="min-h-[350px]" stagger={2}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Projected Scale</h3>

        <div class="space-y-4">
          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-accent">2.5M+</span>
            </div>
            <p class="text-xs text-text-muted">Land Parcels Target</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-accent rounded w-full"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-gold">33</span>
            </div>
            <p class="text-xs text-text-muted">Districts Covered</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-gold rounded w-[100%]"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-green">45K</span>
            </div>
            <p class="text-xs text-text-muted">Villages Connected</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-green rounded w-[90%]"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-accent">$2.1B</span>
            </div>
            <p class="text-xs text-text-muted">Credit to Unlock</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-gradient-to-r from-accent to-green rounded w-[75%]"></div>
            </div>
          </div>
        </div>
      </Card>

      <!-- The Opportunity -->
      <Card colSpan={2} class="min-h-[280px]" stagger={3}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Target class="w-5 h-5 text-gold" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">The Opportunity</h2>
            <p class="text-xs text-text-muted">Understanding the scale</p>
          </div>
        </div>

        <p class="text-text-secondary leading-relaxed mb-4">
          Rajasthan, India's largest state by area, is home to over 80 million people and nearly 69 million hectares of land. Despite India's rapid digitization, land records remain fragmented across colonial-era systems and village-level paper records.
        </p>

        <div class="grid grid-cols-2 gap-4">
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Fragmented Records</h4>
            <p class="text-xs text-text-muted">Land data spread across 6 different legacy systems.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Long Processing</h4>
            <p class="text-xs text-text-muted">Average 47 days for property registration.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Court Backlogs</h4>
            <p class="text-xs text-text-muted">2.3 million pending land-related court cases.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Financial Exclusion</h4>
            <p class="text-xs text-text-muted">Only 28% of rural land usable as bank collateral.</p>
          </div>
        </div>
      </Card>

      <!-- Topography -->
      <TopographyCard label="INDIA" stagger={4} />

      <!-- The Solution -->
      <Card colSpan={3} class="min-h-[320px]" stagger={5}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <Zap class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Proposed Solution Architecture</h2>
            <p class="text-xs text-text-muted">Integrating with India's digital infrastructure</p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-6">
          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/30 flex items-center justify-center mb-3">
              <Shield class="w-5 h-5 text-accent" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Aadhaar Integration</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Secure linking with India's national ID system for biometric verification of landowners.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Biometric verification</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> KYC compliance</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Fraud prevention</li>
            </ul>
          </div>

          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/30 flex items-center justify-center mb-3">
              <Landmark class="w-5 h-5 text-gold" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">DigiLocker Compatible</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Land records accessible through India's official digital document wallet system.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Official integration</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Portable documents</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Verified access</li>
            </ul>
          </div>

          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-green/10 border border-green/30 flex items-center justify-center mb-3">
              <Sun class="w-5 h-5 text-green" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Solar-Powered Nodes</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Decentralized validation nodes at panchayat level, powered by solar for rural reliability.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Off-grid operation</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Local validation</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Sustainable power</li>
            </ul>
          </div>
        </div>
      </Card>

      <!-- Implementation Timeline -->
      <Card colSpan={2} class="min-h-[300px]" stagger={6}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green/20 to-transparent border border-green/30 flex items-center justify-center">
            <Calendar class="w-5 h-5 text-green" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Implementation Roadmap</h2>
            <p class="text-xs text-text-muted">Phased statewide deployment</p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-accent via-gold to-green"></div>

          <div class="space-y-4">
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-accent border-2 border-bg animate-pulse"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-accent">Current</span>
                  <span class="text-sm text-text-primary font-medium">Planning & Design</span>
                </div>
                <p class="text-xs text-text-muted">System architecture, stakeholder alignment, and regulatory approval.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-gold border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-gold">Q2 2025</span>
                  <span class="text-sm text-text-primary font-medium">Pilot District Launch</span>
                </div>
                <p class="text-xs text-text-muted">Jodhpur district pilot with 50,000 parcels.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-green border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-green">Q4 2025</span>
                  <span class="text-sm text-text-primary font-medium">Five-District Expansion</span>
                </div>
                <p class="text-xs text-text-muted">Scale to Jaisalmer, Bikaner, Barmer, and Nagaur districts.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-accent border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-accent">2027</span>
                  <span class="text-sm text-text-primary font-medium">Statewide Rollout</span>
                </div>
                <p class="text-xs text-text-muted">Full deployment across all 33 districts of Rajasthan.</p>
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Testimonial -->
      <Card colSpan={1} class="min-h-[300px]" stagger={7}>
        <Quote class="w-8 h-8 text-accent mb-4" />
        <p class="text-text-secondary italic leading-relaxed mb-6">
          "TerraChain's technology represents the future of land administration. This partnership will not only secure property rights for millions of Rajasthanis but also unlock billions in economic value."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center text-accent font-mono">
            RS
          </div>
          <div>
            <p class="text-sm text-text-primary font-mono">Rajesh Sharma</p>
            <p class="text-xs text-text-muted">Addl. Chief Secretary, Revenue</p>
          </div>
        </div>
      </Card>

      <!-- Partners -->
      <Card colSpan={3} class="min-h-[200px]" stagger={8}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Building class="w-5 h-5 text-gold" />
          </div>
          <h3 class="heading-mono text-lg text-text-primary">Government Partners</h3>
        </div>

        <div class="grid grid-cols-4 gap-4">
          {[
            { name: 'Department of Revenue', role: 'Primary Agency', color: 'accent' },
            { name: 'DoIT&C Rajasthan', role: 'Tech Infrastructure', color: 'gold' },
            { name: 'NABARD', role: 'Agricultural Credit', color: 'green' },
            { name: 'Survey of India', role: 'Geospatial Data', color: 'accent' },
          ].map((partner, i) => (
            <div class="partner-item p-3 bg-surface-hover rounded-lg border border-border text-center" style={`--delay: ${i * 0.1}s`}>
              <p class="text-sm text-text-primary mb-1">{partner.name}</p>
              <p class="text-xs text-text-muted">{partner.role}</p>
            </div>
          ))}
        </div>
      </Card>

      <!-- Impact Metrics -->
      <Card colSpan={2} class="min-h-[200px]" stagger={9}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <BarChart3 class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Projected Impact</h2>
            <p class="text-xs text-text-muted">Expected outcomes</p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-accent">72%</span>
            <p class="text-xs text-text-muted mt-2">Time Reduction</p>
            <p class="text-xs text-text-secondary mt-1">In registration process</p>
          </div>
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-gold">$2.1B</span>
            <p class="text-xs text-text-muted mt-2">Credit Unlocked</p>
            <p class="text-xs text-text-secondary mt-1">Agricultural loans enabled</p>
          </div>
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-green">80M</span>
            <p class="text-xs text-text-muted mt-2">Citizens Served</p>
            <p class="text-xs text-text-secondary mt-1">Statewide population</p>
          </div>
        </div>
      </Card>

      <!-- Download CTA -->
      <Card colSpan={1} class="min-h-[200px] flex flex-col justify-center group" stagger={10} glow accent>
        <div class="text-center">
          <Mascot size="md" pose="pointing" />
          <h3 class="text-lg text-text-primary mt-4 mb-2">Partnership Prospectus</h3>
          <p class="text-xs text-text-secondary mb-4">
            Join India's largest blockchain land registry
          </p>
          <a href="/reports/india-prospectus.pdf" class="btn btn-primary inline-flex items-center gap-2 no-underline text-sm">
            <Download class="w-4 h-4" />
            <span>Download PDF</span>
          </a>
        </div>
      </Card>

      <!-- Next Case Study -->
      <Card colSpan={3} class="min-h-[120px] py-4" stagger={11}>
        <div class="flex items-center justify-between">
          <a href="/case-studies/colombia" class="group flex items-center gap-4 no-underline">
            <ArrowLeft class="w-5 h-5 text-text-muted group-hover:text-accent group-hover:-translate-x-1 transition-all" />
            <div>
              <p class="text-xs text-text-muted font-mono">PREVIOUS</p>
              <p class="text-sm text-text-primary group-hover:text-accent transition-colors">Colombia Peace Process</p>
            </div>
          </a>

          <a href="/case-studies/rwanda" class="group flex items-center gap-4 no-underline text-right">
            <div>
              <p class="text-xs text-text-muted font-mono">FIRST CASE STUDY</p>
              <p class="text-sm text-text-primary group-hover:text-accent transition-colors">Rwanda Rural Lands</p>
            </div>
            <ArrowRight class="w-5 h-5 text-text-muted group-hover:text-accent group-hover:translate-x-1 transition-all" />
          </a>
        </div>
      </Card>
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .text-gradient-gold {
    background: linear-gradient(135deg, var(--color-gold), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .challenge-item,
  .solution-card,
  .impact-card,
  .partner-item {
    animation: fadeInUp 0.4s ease-out forwards;
    opacity: 0;
  }

  .challenge-item:nth-child(1) { animation-delay: 0.1s; }
  .challenge-item:nth-child(2) { animation-delay: 0.2s; }
  .challenge-item:nth-child(3) { animation-delay: 0.3s; }
  .challenge-item:nth-child(4) { animation-delay: 0.4s; }

  .solution-card:nth-child(1) { animation-delay: 0.1s; }
  .solution-card:nth-child(2) { animation-delay: 0.2s; }
  .solution-card:nth-child(3) { animation-delay: 0.3s; }

  .impact-card:nth-child(1) { animation-delay: 0.1s; }
  .impact-card:nth-child(2) { animation-delay: 0.2s; }
  .impact-card:nth-child(3) { animation-delay: 0.3s; }

  .timeline-item {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
  }

  .timeline-item:nth-child(1) { animation-delay: 0.1s; }
  .timeline-item:nth-child(2) { animation-delay: 0.2s; }
  .timeline-item:nth-child(3) { animation-delay: 0.3s; }
  .timeline-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .challenge-item,
    .solution-card,
    .impact-card,
    .partner-item,
    .timeline-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
