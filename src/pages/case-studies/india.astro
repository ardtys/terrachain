---
import Layout from '@layouts/Layout.astro';
import Card from '@components/ui/Card.astro';
import { ArrowLeft, ArrowRight, MapPin, Users, FileCheck, Clock, Calendar, CheckCircle, Quote, Download, Target, Shield, Building, Landmark, Wheat, Droplets, Sun, Compass } from 'lucide-astro';
---

<Layout title="India Case Study - TerraChain">
  <main class="min-h-screen bg-background">
    <!-- Back Navigation -->
    <section class="pt-24 pb-8">
      <div class="max-w-6xl mx-auto px-6">
        <a href="/case-studies" class="inline-flex items-center gap-2 text-text-secondary hover:text-accent transition-colors group">
          <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
          <span>Back to Case Studies</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="animate-fadeInUp">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-medium mb-6">
              <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
              Planning Phase
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary mb-6">
              India: <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-orange-400">Rajasthan Digital Land Initiative</span>
            </h1>
            <p class="text-xl text-text-secondary leading-relaxed mb-8">
              Partnering with Rajasthan's state government to modernize land records across India's largest state, bringing blockchain-secured titles to millions of rural landowners in the Thar Desert region.
            </p>
            <div class="flex items-center gap-4 text-text-secondary">
              <MapPin class="w-5 h-5 text-accent" />
              <span>Rajasthan State, Western India</span>
            </div>
          </div>

          <div class="animate-fadeInUp" style="animation-delay: 0.2s;">
            <Card variant="glass" class="p-8">
              <div class="text-center mb-6">
                <div class="text-sm text-text-secondary mb-2">Projected Scale</div>
                <div class="text-4xl font-bold text-accent">2.5M+</div>
                <div class="text-text-secondary">Land Parcels</div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-2xl font-bold text-green-400 mb-1">33</div>
                  <div class="text-sm text-text-secondary">Districts</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-2xl font-bold text-blue-400 mb-1">45K</div>
                  <div class="text-sm text-text-secondary">Villages</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-2xl font-bold text-orange-400 mb-1">Q2</div>
                  <div class="text-sm text-text-secondary">2025 Pilot</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-2xl font-bold text-purple-400 mb-1">5</div>
                  <div class="text-sm text-text-secondary">Pilot Districts</div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- The Opportunity -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12">
          <div class="animate-slideInLeft">
            <h2 class="text-3xl font-bold text-text-primary mb-6">The Opportunity</h2>
            <div class="space-y-4 text-text-secondary leading-relaxed">
              <p>
                Rajasthan, India's largest state by area, is home to over 80 million people and nearly 69 million hectares of land. Despite India's rapid digitization efforts, land records remain fragmented across colonial-era systems, state databases, and village-level paper records.
              </p>
              <p>
                The state government's ambitious Digital Rajasthan initiative aims to create a unified, tamper-proof land registry that will transform how land is owned, transferred, and used as collateral. TerraChain has been selected as a technology partner for this groundbreaking project.
              </p>
              <p>
                This pilot will be India's largest blockchain-based land registry implementation, potentially serving as a model for other states and eventually the entire nation's 140 million land parcels.
              </p>
            </div>
          </div>

          <div class="animate-slideInLeft" style="animation-delay: 0.2s;">
            <Card variant="elevated" class="p-6 h-full">
              <h3 class="text-xl font-semibold text-text-primary mb-4">Current Challenges</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center flex-shrink-0">
                    <FileCheck class="w-4 h-4 text-red-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Fragmented Records</div>
                    <div class="text-sm text-text-secondary">Land data spread across 6 different legacy systems</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-500/10 flex items-center justify-center flex-shrink-0">
                    <Clock class="w-4 h-4 text-orange-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Long Processing Times</div>
                    <div class="text-sm text-text-secondary">Average 47 days for property registration</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                    <Users class="w-4 h-4 text-yellow-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Inheritance Disputes</div>
                    <div class="text-sm text-text-secondary">2.3 million pending land-related court cases</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center flex-shrink-0">
                    <Landmark class="w-4 h-4 text-purple-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Financial Exclusion</div>
                    <div class="text-sm text-text-secondary">Only 28% of rural land usable as bank collateral</div>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Desert Topography Decoration -->
    <section class="py-8">
      <div class="max-w-6xl mx-auto px-6">
        <Card variant="glass" class="p-4 overflow-hidden">
          <div class="flex items-end justify-between gap-2 opacity-30">
            {[...Array(24)].map((_, i) => (
              <div class="flex-1 rounded-t bg-gradient-to-t from-orange-500/30 to-yellow-500/10"
                   style={`height: ${20 + Math.sin(i * 0.3) * 15 + Math.random() * 20}px`}></div>
            ))}
          </div>
          <div class="text-center text-text-secondary text-sm mt-2">Thar Desert Dune Profile: Jaisalmer to Jodhpur</div>
        </Card>
      </div>
    </section>

    <!-- Proposed Solution -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-12 animate-fadeInUp">
          <h2 class="text-3xl font-bold text-text-primary mb-4">Proposed Solution Architecture</h2>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto">
            A comprehensive digital land ecosystem designed to integrate with India's existing digital infrastructure while providing unprecedented security and transparency.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <Card variant="elevated" class="p-6 animate-fadeInUp">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent/20 to-accent/5 flex items-center justify-center mb-4">
              <Shield class="w-6 h-6 text-accent" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Aadhaar Integration</h3>
            <p class="text-text-secondary text-sm">
              Secure linking with India's national ID system for biometric verification, ensuring only legitimate owners can authorize transactions.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.1s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500/20 to-green-500/5 flex items-center justify-center mb-4">
              <Landmark class="w-6 h-6 text-green-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">DigiLocker Compatibility</h3>
            <p class="text-text-secondary text-sm">
              Land records accessible through India's official digital document wallet, making titles available alongside other verified documents.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.2s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-500/5 flex items-center justify-center mb-4">
              <Sun class="w-6 h-6 text-blue-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Solar-Powered Nodes</h3>
            <p class="text-text-secondary text-sm">
              Decentralized validation nodes at panchayat (village council) level, powered by solar energy for reliable operation in rural areas.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.3s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-500/5 flex items-center justify-center mb-4">
              <Compass class="w-6 h-6 text-purple-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Satellite Boundary Mapping</h3>
            <p class="text-text-secondary text-sm">
              Partnership with ISRO (Indian Space Research Organisation) for high-resolution boundary mapping using indigenous satellites.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.4s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500/20 to-orange-500/5 flex items-center justify-center mb-4">
              <Wheat class="w-6 h-6 text-orange-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Agricultural Credit Link</h3>
            <p class="text-text-secondary text-sm">
              Direct integration with NABARD and regional rural banks to enable instant land-backed agricultural loans for farmers.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.5s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500/20 to-cyan-500/5 flex items-center justify-center mb-4">
              <Droplets class="w-6 h-6 text-cyan-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Water Rights Registry</h3>
            <p class="text-text-secondary text-sm">
              Integrated groundwater rights documentation—critical for the water-scarce Thar Desert region—linked to land ownership.
            </p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Implementation Timeline -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Implementation Roadmap</h2>

        <div class="relative">
          <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-px bg-border"></div>

          <div class="space-y-12">
            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-blue-400 font-medium mb-1">Current Phase</div>
                  <div class="font-semibold text-text-primary">Planning & Design</div>
                  <div class="text-sm text-text-secondary">System architecture, stakeholder alignment, and regulatory approval</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-blue-400 border-4 border-background animate-pulse"></div>
              <div class="w-5/12"></div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12"></div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-accent border-4 border-background"></div>
              <div class="w-5/12 pl-8 animate-slideInLeft" style="animation-delay: 0.1s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-accent font-medium mb-1">Q2 2025</div>
                  <div class="font-semibold text-text-primary">Pilot District Launch</div>
                  <div class="text-sm text-text-secondary">Jodhpur district pilot with 50,000 parcels</div>
                </Card>
              </div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft" style="animation-delay: 0.2s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-green-400 font-medium mb-1">Q4 2025</div>
                  <div class="font-semibold text-text-primary">Five-District Expansion</div>
                  <div class="text-sm text-text-secondary">Scale to Jaisalmer, Bikaner, Barmer, and Nagaur districts</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-green-400 border-4 border-background"></div>
              <div class="w-5/12"></div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12"></div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-purple-400 border-4 border-background"></div>
              <div class="w-5/12 pl-8 animate-slideInLeft" style="animation-delay: 0.3s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-purple-400 font-medium mb-1">2026</div>
                  <div class="font-semibold text-text-primary">Bank Integration</div>
                  <div class="text-sm text-text-secondary">Connect with NABARD and 12 regional rural banks</div>
                </Card>
              </div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft" style="animation-delay: 0.4s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-orange-400 font-medium mb-1">2027</div>
                  <div class="font-semibold text-text-primary">Statewide Rollout</div>
                  <div class="text-sm text-text-secondary">Full deployment across all 33 districts of Rajasthan</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-orange-400 border-4 border-background"></div>
              <div class="w-5/12"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Government Partnership -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="animate-fadeInUp">
            <h2 class="text-3xl font-bold text-text-primary mb-6">Government Partnership</h2>
            <p class="text-text-secondary leading-relaxed mb-6">
              The Rajasthan Digital Land Initiative is a flagship project under the state's comprehensive digital transformation agenda, with full support from the highest levels of government.
            </p>

            <div class="space-y-4">
              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <Building class="w-5 h-5 text-accent" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">Department of Revenue</div>
                  <div class="text-sm text-text-secondary">Primary implementing agency</div>
                </div>
              </div>

              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-orange-500/10 flex items-center justify-center">
                  <Landmark class="w-5 h-5 text-orange-400" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">DoIT&C Rajasthan</div>
                  <div class="text-sm text-text-secondary">Technology infrastructure partner</div>
                </div>
              </div>

              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-green-500/10 flex items-center justify-center">
                  <Wheat class="w-5 h-5 text-green-400" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">NABARD</div>
                  <div class="text-sm text-text-secondary">Agricultural credit integration</div>
                </div>
              </div>

              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center">
                  <Compass class="w-5 h-5 text-blue-400" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">Survey of India</div>
                  <div class="text-sm text-text-secondary">Geospatial data and mapping</div>
                </div>
              </div>
            </div>
          </div>

          <div class="animate-fadeInUp" style="animation-delay: 0.2s;">
            <Card variant="gradient" class="p-8">
              <Quote class="w-10 h-10 text-accent/30 mb-4" />
              <blockquote class="text-xl text-text-primary leading-relaxed mb-6">
                "TerraChain's technology represents the future of land administration. This partnership will not only secure property rights for millions of Rajasthanis but also unlock billions in economic value currently trapped in unclear titles."
              </blockquote>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center">
                  <span class="text-accent font-bold">RS</span>
                </div>
                <div>
                  <div class="font-medium text-text-primary">Rajesh Sharma</div>
                  <div class="text-sm text-text-secondary">Additional Chief Secretary, Revenue Department</div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Projected Impact -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Projected Impact</h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card variant="glass" class="p-6 text-center animate-fadeInUp">
            <div class="text-4xl font-bold text-accent mb-2">2.5M</div>
            <div class="text-text-secondary">Parcels to be secured</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.1s;">
            <div class="text-4xl font-bold text-green-400 mb-2">72%</div>
            <div class="text-text-secondary">Reduction in registration time</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.2s;">
            <div class="text-4xl font-bold text-blue-400 mb-2">$2.1B</div>
            <div class="text-text-secondary">Projected credit unlocked</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.3s;">
            <div class="text-4xl font-bold text-orange-400 mb-2">45K</div>
            <div class="text-text-secondary">Villages connected</div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Get Involved Section -->
    <section class="py-16">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <Card variant="gradient" class="p-12 animate-fadeInUp">
          <h2 class="text-3xl font-bold text-text-primary mb-4">Join the Initiative</h2>
          <p class="text-xl text-text-secondary mb-8">
            We're seeking partners across technology, finance, and development sectors to support India's largest blockchain land registry project. Download our partnership prospectus to learn more.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/docs/india-rajasthan-prospectus.pdf" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-accent text-background font-semibold hover:bg-accent/90 transition-all no-underline">
              <Download class="w-5 h-5" />
              Download Prospectus
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border text-text-primary font-semibold hover:bg-surface-hover transition-all no-underline">
              Become a Partner
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>
        </Card>
      </div>
    </section>

    <!-- Next Case Study -->
    <section class="py-16 border-t border-border">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between">
          <a href="/case-studies/colombia" class="group flex items-center gap-4 text-text-secondary hover:text-accent transition-colors">
            <ArrowLeft class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
            <div>
              <div class="text-sm">Previous Case Study</div>
              <div class="font-semibold text-text-primary group-hover:text-accent transition-colors">Colombia Peace Process</div>
            </div>
          </a>

          <a href="/case-studies/rwanda" class="group flex items-center gap-4 text-text-secondary hover:text-accent transition-colors text-right">
            <div>
              <div class="text-sm">First Case Study</div>
              <div class="font-semibold text-text-primary group-hover:text-accent transition-colors">Rwanda Rural Lands</div>
            </div>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fadeInUp {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .animate-slideInLeft {
    animation: slideInLeft 0.6s ease-out forwards;
  }
</style>
