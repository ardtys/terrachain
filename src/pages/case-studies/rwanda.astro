---
import BaseLayout from '@layouts/BaseLayout.astro';
import BentoGrid from '@components/shared/BentoGrid.astro';
import Card from '@components/shared/Card.astro';
import TopographyCard from '@components/cards/TopographyCard.astro';
import Mascot from '@components/decorative/Mascot.astro';
import { MapPin, Users, Clock, TrendingUp, ArrowRight, ArrowLeft, Check, Globe, Building, Smartphone, Shield, FileText, Quote, Calendar, Target, Zap, Award, Download, ChevronRight, BarChart3, Leaf } from 'lucide-astro';
---

<BaseLayout
  title="Rwanda Case Study — TerraChain"
  description="How TerraChain transformed rural land registration in Rwanda's Eastern Province, securing 18,000+ parcels for smallholder farmers."
>
  <div class="pt-24 pb-8">
    <BentoGrid>
      <!-- Back Navigation -->
      <Card colSpan={3} class="min-h-[60px] py-3" stagger={0}>
        <a href="/case-studies" class="inline-flex items-center gap-2 text-text-muted hover:text-accent transition-colors no-underline">
          <ArrowLeft class="w-4 h-4" />
          <span class="text-sm">Back to Case Studies</span>
        </a>
      </Card>

      <!-- Hero Section -->
      <Card colSpan={2} class="min-h-[350px] relative overflow-hidden" stagger={1} glow>
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-radial from-accent/10 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-radial from-green/10 to-transparent rounded-full blur-2xl"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <MapPin class="w-5 h-5 text-accent" />
            <span class="text-xs text-accent font-mono uppercase tracking-wider">Rwanda • Eastern Province</span>
          </div>

          <h1 class="text-3xl md:text-4xl text-text-primary mb-4 leading-tight">
            Rural Land Initiative:<br/>
            <span class="text-gradient-accent">Empowering Smallholder Farmers</span>
          </h1>

          <p class="text-text-secondary max-w-lg mb-6">
            In partnership with the Rwanda Land Management Authority (RLMA), TerraChain deployed a mobile-first land registration system across the Eastern Province, transforming how smallholder farmers secure their property rights.
          </p>

          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 text-xs font-mono bg-green/10 border border-green/30 rounded-full text-green flex items-center gap-2">
              <Check class="w-3 h-3" /> Completed
            </span>
            <span class="px-3 py-1.5 text-xs font-mono bg-surface-hover border border-border rounded-full text-text-secondary flex items-center gap-2">
              <Calendar class="w-3 h-3" /> 2023 - 2024
            </span>
          </div>
        </div>
      </Card>

      <!-- Key Metrics -->
      <Card colSpan={1} class="min-h-[350px]" stagger={2}>
        <h3 class="heading-mono text-sm text-text-primary mb-4">Key Results</h3>

        <div class="space-y-4">
          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-accent">18,247</span>
            </div>
            <p class="text-xs text-text-muted">Parcels registered</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-accent rounded w-full"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-gold">15 min</span>
            </div>
            <p class="text-xs text-text-muted">Average registration time</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-gold rounded w-[95%]"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-green">$0.85</span>
            </div>
            <p class="text-xs text-text-muted">Cost per registration</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-green rounded w-[99%]"></div>
            </div>
          </div>

          <div class="metric">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-3xl font-mono text-accent">99.8%</span>
            </div>
            <p class="text-xs text-text-muted">Success rate</p>
            <div class="h-1 bg-surface-hover rounded mt-2">
              <div class="h-full bg-gradient-to-r from-accent to-green rounded w-[99.8%]"></div>
            </div>
          </div>
        </div>
      </Card>

      <!-- The Challenge -->
      <Card colSpan={2} class="min-h-[280px]" stagger={3}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Target class="w-5 h-5 text-gold" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">The Challenge</h2>
            <p class="text-xs text-text-muted">Understanding the problem</p>
          </div>
        </div>

        <p class="text-text-secondary leading-relaxed mb-4">
          Rwanda's Eastern Province is home to over 2 million smallholder farmers, many of whom rely on agriculture as their primary source of income. Despite significant progress in land reform, challenges persisted:
        </p>

        <div class="grid grid-cols-2 gap-4">
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Physical Distance</h4>
            <p class="text-xs text-text-muted">District land offices were often 50+ kilometers away, requiring farmers to spend entire days traveling for simple registrations.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">High Costs</h4>
            <p class="text-xs text-text-muted">Traditional registration costs of $15-25 per parcel represented weeks of income for subsistence farmers.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Paper-Based System</h4>
            <p class="text-xs text-text-muted">Existing records were vulnerable to damage, loss, and manipulation, creating uncertainty in ownership.</p>
          </div>
          <div class="challenge-item p-3 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Limited Literacy</h4>
            <p class="text-xs text-text-muted">Many farmers struggled with complex documentation requirements and legal terminology.</p>
          </div>
        </div>
      </Card>

      <!-- Topography -->
      <TopographyCard label="RWANDA" stagger={4} />

      <!-- The Solution -->
      <Card colSpan={3} class="min-h-[320px]" stagger={5}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <Zap class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Our Solution</h2>
            <p class="text-xs text-text-muted">Mobile-first land registration</p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-6">
          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/30 flex items-center justify-center mb-3">
              <Smartphone class="w-5 h-5 text-accent" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Mobile App</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Custom Android application designed for low-bandwidth environments with offline-first architecture.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Works on 2G networks</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Offline data collection</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Kinyarwanda interface</li>
            </ul>
          </div>

          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-gold/10 border border-gold/30 flex items-center justify-center mb-3">
              <MapPin class="w-5 h-5 text-gold" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">GPS Mapping</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Smartphone GPS with sub-3-meter accuracy for boundary demarcation, validated by PostGIS.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Walk-the-boundary capture</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Automatic overlap detection</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Satellite imagery overlay</li>
            </ul>
          </div>

          <div class="solution-card p-4 bg-surface-hover rounded-lg border border-border">
            <div class="w-10 h-10 rounded-lg bg-green/10 border border-green/30 flex items-center justify-center mb-3">
              <Users class="w-5 h-5 text-green" />
            </div>
            <h4 class="text-sm text-text-primary font-mono mb-2">Community Validation</h4>
            <p class="text-xs text-text-muted leading-relaxed mb-3">
              Multi-signature approval involving neighbors, village leaders, and district officials.
            </p>
            <ul class="space-y-1 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Biometric witness signatures</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> SMS notifications</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> National ID integration</li>
            </ul>
          </div>
        </div>
      </Card>

      <!-- Implementation Timeline -->
      <Card colSpan={2} class="min-h-[300px]" stagger={6}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green/20 to-transparent border border-green/30 flex items-center justify-center">
            <Calendar class="w-5 h-5 text-green" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Implementation Timeline</h2>
            <p class="text-xs text-text-muted">12-month deployment</p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-accent via-gold to-green"></div>

          <div class="space-y-4">
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-accent border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-accent">Q1 2023</span>
                  <span class="text-sm text-text-primary font-medium">Pilot Launch</span>
                </div>
                <p class="text-xs text-text-muted">Deployed in Rwamagana District with 50 trained field agents. Initial target: 2,000 parcels.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-gold border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-gold">Q2 2023</span>
                  <span class="text-sm text-text-primary font-medium">Expansion</span>
                </div>
                <p class="text-xs text-text-muted">Extended to Kayonza and Ngoma districts. Added SMS verification system for farmers without smartphones.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-green border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-green">Q3-Q4 2023</span>
                  <span class="text-sm text-text-primary font-medium">Full Rollout</span>
                </div>
                <p class="text-xs text-text-muted">Province-wide deployment covering all 7 districts. Integration with national land information system.</p>
              </div>
            </div>
            <div class="timeline-item flex items-start gap-4 pl-8 relative">
              <div class="absolute left-2 w-4 h-4 rounded-full bg-accent border-2 border-bg"></div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-mono text-accent">Q1 2024</span>
                  <span class="text-sm text-text-primary font-medium">Completion</span>
                </div>
                <p class="text-xs text-text-muted">Project milestone achieved with 18,247 parcels registered and full handover to RLMA.</p>
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Testimonial -->
      <Card colSpan={1} class="min-h-[300px]" stagger={7}>
        <Quote class="w-8 h-8 text-accent mb-4" />
        <p class="text-text-secondary italic leading-relaxed mb-6">
          "For the first time in my life, I have proof that this land belongs to my family. My grandfather farmed this land, my father farmed it, and now my children will inherit it with certainty. I can finally approach the bank for a loan to buy better seeds."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center text-accent font-mono">
            JM
          </div>
          <div>
            <p class="text-sm text-text-primary font-mono">Jean-Baptiste Mugabo</p>
            <p class="text-xs text-text-muted">Farmer, Rwamagana District</p>
          </div>
        </div>
      </Card>

      <!-- Impact Metrics -->
      <Card colSpan={3} class="min-h-[280px]" stagger={8}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <BarChart3 class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Measurable Impact</h2>
            <p class="text-xs text-text-muted">Quantified outcomes</p>
          </div>
        </div>

        <div class="grid grid-cols-4 gap-4">
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-accent">89%</span>
            <p class="text-xs text-text-muted mt-2">Reduction in registration time</p>
            <p class="text-xs text-text-secondary mt-1">From 3 days to 15 minutes</p>
          </div>
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-gold">$45M</span>
            <p class="text-xs text-text-muted mt-2">Dead capital unlocked</p>
            <p class="text-xs text-text-secondary mt-1">Property now usable as collateral</p>
          </div>
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-green">94%</span>
            <p class="text-xs text-text-muted mt-2">Cost reduction</p>
            <p class="text-xs text-text-secondary mt-1">From $15 to $0.85 per parcel</p>
          </div>
          <div class="impact-card p-4 bg-surface-hover rounded-lg border border-border text-center">
            <span class="text-3xl font-mono text-accent">0</span>
            <p class="text-xs text-text-muted mt-2">Fraud cases</p>
            <p class="text-xs text-text-secondary mt-1">Zero successful manipulations</p>
          </div>
        </div>
      </Card>

      <!-- Lessons Learned -->
      <Card colSpan={2} class="min-h-[250px]" stagger={9}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Leaf class="w-5 h-5 text-gold" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Lessons Learned</h2>
            <p class="text-xs text-text-muted">Insights for future deployments</p>
          </div>
        </div>

        <div class="space-y-3">
          {[
            { title: 'Local language support is critical', desc: 'Kinyarwanda interface increased adoption by 340% compared to English-only pilot.' },
            { title: 'Train community leaders first', desc: 'Village chiefs became advocates, accelerating trust-building in their communities.' },
            { title: 'SMS fallback is essential', desc: '60% of verification queries came via SMS from farmers without smartphones.' },
            { title: 'Offline mode is non-negotiable', desc: 'Field agents spent 40% of time in areas with no mobile connectivity.' },
          ].map((lesson, i) => (
            <div class="lesson-item flex items-start gap-3 p-3 bg-surface-hover rounded-lg">
              <div class="w-6 h-6 rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-xs font-mono text-accent">{i + 1}</span>
              </div>
              <div>
                <h4 class="text-sm text-text-primary font-mono mb-1">{lesson.title}</h4>
                <p class="text-xs text-text-muted">{lesson.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </Card>

      <!-- Partner Quote -->
      <Card colSpan={1} class="min-h-[250px]" stagger={10}>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green/20 to-transparent border border-green/30 flex items-center justify-center">
            <Award class="w-5 h-5 text-green" />
          </div>
          <h3 class="heading-mono text-sm text-text-primary">Partner Perspective</h3>
        </div>

        <Quote class="w-6 h-6 text-green mb-3" />
        <p class="text-sm text-text-secondary italic leading-relaxed mb-4">
          "TerraChain has demonstrated what digital transformation in land administration can achieve. This partnership sets a new standard for Africa."
        </p>
        <div>
          <p class="text-sm text-text-primary font-mono">Jean-Pierre Habimana</p>
          <p class="text-xs text-text-muted">Director, Rwanda Land Management Authority</p>
        </div>
      </Card>

      <!-- Download Report CTA -->
      <Card colSpan={2} class="min-h-[180px] relative overflow-hidden group" stagger={11} glow accent>
        <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-green/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative z-10 flex items-center justify-between">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <FileText class="w-5 h-5 text-accent" />
              <span class="text-xs text-accent font-mono uppercase tracking-wider">Full Report</span>
            </div>
            <h3 class="text-xl text-text-primary mb-2">Download the Complete Case Study</h3>
            <p class="text-sm text-text-secondary max-w-md mb-4">
              Detailed analysis including methodology, data, and recommendations for replication.
            </p>
            <a href="/reports/rwanda-case-study.pdf" class="btn btn-primary inline-flex items-center gap-2 no-underline">
              <Download class="w-4 h-4" />
              <span>Download PDF</span>
            </a>
          </div>

          <div class="hidden md:block">
            <Mascot size="md" pose="pointing" />
          </div>
        </div>
      </Card>

      <!-- Next Case Study -->
      <Card colSpan={1} class="min-h-[180px] flex flex-col justify-center" stagger={12}>
        <p class="text-xs text-text-muted font-mono mb-2">NEXT CASE STUDY</p>
        <a href="/case-studies/philippines" class="group no-underline">
          <h3 class="text-lg text-text-primary group-hover:text-accent transition-colors mb-2">Philippines: Urban Settlements</h3>
          <p class="text-sm text-text-secondary mb-3">Securing tenure for 3,200 families in Metro Manila's informal settlements.</p>
          <span class="inline-flex items-center gap-2 text-accent text-sm">
            Read Case Study
            <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
          </span>
        </a>
      </Card>
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .text-gradient-accent {
    background: linear-gradient(135deg, var(--color-accent), var(--color-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .challenge-item,
  .solution-card,
  .impact-card,
  .lesson-item {
    animation: fadeInUp 0.4s ease-out forwards;
    opacity: 0;
  }

  .challenge-item:nth-child(1) { animation-delay: 0.1s; }
  .challenge-item:nth-child(2) { animation-delay: 0.2s; }
  .challenge-item:nth-child(3) { animation-delay: 0.3s; }
  .challenge-item:nth-child(4) { animation-delay: 0.4s; }

  .solution-card:nth-child(1) { animation-delay: 0.1s; }
  .solution-card:nth-child(2) { animation-delay: 0.2s; }
  .solution-card:nth-child(3) { animation-delay: 0.3s; }

  .impact-card:nth-child(1) { animation-delay: 0.1s; }
  .impact-card:nth-child(2) { animation-delay: 0.2s; }
  .impact-card:nth-child(3) { animation-delay: 0.3s; }
  .impact-card:nth-child(4) { animation-delay: 0.4s; }

  .timeline-item {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
  }

  .timeline-item:nth-child(1) { animation-delay: 0.1s; }
  .timeline-item:nth-child(2) { animation-delay: 0.2s; }
  .timeline-item:nth-child(3) { animation-delay: 0.3s; }
  .timeline-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .challenge-item,
    .solution-card,
    .impact-card,
    .lesson-item,
    .timeline-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
