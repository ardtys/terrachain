---
import Layout from '@layouts/Layout.astro';
import Card from '@components/ui/Card.astro';
import { ArrowLeft, ArrowRight, MapPin, Users, FileCheck, Clock, Calendar, CheckCircle, Quote, Download, Target, Shield, Handshake, Scale, Heart, Building } from 'lucide-astro';
---

<Layout title="Colombia Case Study - TerraChain">
  <main class="min-h-screen bg-background">
    <!-- Back Navigation -->
    <section class="pt-24 pb-8">
      <div class="max-w-6xl mx-auto px-6">
        <a href="/case-studies" class="inline-flex items-center gap-2 text-text-secondary hover:text-accent transition-colors group">
          <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
          <span>Back to Case Studies</span>
        </a>
      </div>
    </section>

    <!-- Hero Section -->
    <section class="pb-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="animate-fadeInUp">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-sm font-medium mb-6">
              <span class="w-2 h-2 rounded-full bg-yellow-400 animate-pulse"></span>
              Launching 2024
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary mb-6">
              Colombia: <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-green-400">Peace Through Land Rights</span>
            </h1>
            <p class="text-xl text-text-secondary leading-relaxed mb-8">
              Supporting Colombia's peace process by securing land rights for displaced families and former conflict zones, turning contested territories into documented, legally protected properties.
            </p>
            <div class="flex items-center gap-4 text-text-secondary">
              <MapPin class="w-5 h-5 text-accent" />
              <span>Meta, Caquetá, and Putumayo Departments</span>
            </div>
          </div>

          <div class="animate-fadeInUp" style="animation-delay: 0.2s;">
            <Card variant="glass" class="p-8">
              <div class="grid grid-cols-2 gap-6">
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-3xl font-bold text-accent mb-1">3,147</div>
                  <div class="text-sm text-text-secondary">Parcels Mapped</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-3xl font-bold text-green-400 mb-1">1,284</div>
                  <div class="text-sm text-text-secondary">Families Returned</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-3xl font-bold text-blue-400 mb-1">89%</div>
                  <div class="text-sm text-text-secondary">Dispute Resolution</div>
                </div>
                <div class="text-center p-4 rounded-xl bg-surface-hover">
                  <div class="text-3xl font-bold text-purple-400 mb-1">12</div>
                  <div class="text-sm text-text-secondary">Municipalities</div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- The Challenge -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12">
          <div class="animate-slideInLeft">
            <h2 class="text-3xl font-bold text-text-primary mb-6">The Challenge</h2>
            <div class="space-y-4 text-text-secondary leading-relaxed">
              <p>
                Colombia's five-decade armed conflict displaced over 7 million people—more than any other country except Syria. As the 2016 peace agreement takes hold, millions of families are seeking to return to lands they fled, but face seemingly insurmountable obstacles.
              </p>
              <p>
                Land records were destroyed, altered, or never existed. Overlapping claims from displaced families, current occupants, and agroindustrial interests create complex disputes. Traditional resolution through courts takes an average of 12 years—time that displaced families cannot afford.
              </p>
              <p>
                The Comprehensive Rural Reform, a cornerstone of the peace agreement, depends on resolving these land issues. Without secure tenure, returnees cannot access credit, invest in their properties, or truly rebuild their lives. The peace process itself hangs in the balance.
              </p>
            </div>
          </div>

          <div class="animate-slideInLeft" style="animation-delay: 0.2s;">
            <Card variant="elevated" class="p-6 h-full">
              <h3 class="text-xl font-semibold text-text-primary mb-4">Key Obstacles</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center flex-shrink-0">
                    <FileCheck class="w-4 h-4 text-red-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Destroyed Documentation</div>
                    <div class="text-sm text-text-secondary">60% of rural land records lost or damaged during conflict</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-500/10 flex items-center justify-center flex-shrink-0">
                    <Users class="w-4 h-4 text-orange-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Overlapping Claims</div>
                    <div class="text-sm text-text-secondary">Average of 3.2 claimants per disputed parcel</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                    <Clock class="w-4 h-4 text-yellow-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Slow Resolution</div>
                    <div class="text-sm text-text-secondary">12-year average for land restitution cases in courts</div>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center flex-shrink-0">
                    <Shield class="w-4 h-4 text-purple-400" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Security Concerns</div>
                    <div class="text-sm text-text-secondary">Ongoing threats to land activists and returnees</div>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Topography Decoration -->
    <section class="py-8">
      <div class="max-w-6xl mx-auto px-6">
        <Card variant="glass" class="p-4 overflow-hidden">
          <div class="flex items-center justify-between gap-4 opacity-30">
            {[...Array(20)].map((_, i) => (
              <div class="flex-1 h-24 rounded bg-gradient-to-t from-accent/20 to-transparent"
                   style={`height: ${30 + Math.sin(i * 0.5) * 20 + Math.random() * 30}px`}></div>
            ))}
          </div>
          <div class="text-center text-text-secondary text-sm mt-2">Andean Terrain Profile: Meta to Caquetá</div>
        </Card>
      </div>
    </section>

    <!-- Our Approach -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-12 animate-fadeInUp">
          <h2 class="text-3xl font-bold text-text-primary mb-4">Our Peace-Building Approach</h2>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto">
            Working with the Colombian Land Restitution Unit and international peacebuilding organizations to create a transparent, trusted system for resolving land claims.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <Card variant="elevated" class="p-6 animate-fadeInUp">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent/20 to-accent/5 flex items-center justify-center mb-4">
              <FileCheck class="w-6 h-6 text-accent" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Historical Evidence Digitization</h3>
            <p class="text-text-secondary text-sm">
              Scanning and blockchain-anchoring of surviving records, aerial photographs from different eras, and witness testimonies to reconstruct ownership histories.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.1s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500/20 to-green-500/5 flex items-center justify-center mb-4">
              <Handshake class="w-6 h-6 text-green-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Community Mediation</h3>
            <p class="text-text-secondary text-sm">
              AI-assisted dispute identification combined with trained community mediators to resolve overlapping claims through consensus rather than adversarial proceedings.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.2s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-500/5 flex items-center justify-center mb-4">
              <Scale class="w-6 h-6 text-blue-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Truth Commission Integration</h3>
            <p class="text-text-secondary text-sm">
              Linking land records with testimonies from the Truth Commission to create an immutable historical record that supports both restitution and reconciliation.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.3s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-500/5 flex items-center justify-center mb-4">
              <Shield class="w-6 h-6 text-purple-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Protected Identity System</h3>
            <p class="text-text-secondary text-sm">
              Zero-knowledge proofs allow returnees to prove land claims without exposing identities to potential threats, protecting vulnerable families during the transition.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.4s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-yellow-500/20 to-yellow-500/5 flex items-center justify-center mb-4">
              <Building class="w-6 h-6 text-yellow-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Peace Infrastructure</h3>
            <p class="text-text-secondary text-sm">
              Local offices in former conflict zones provide in-person support, combining digital verification with human guidance for families unfamiliar with technology.
            </p>
          </Card>

          <Card variant="elevated" class="p-6 animate-fadeInUp" style="animation-delay: 0.5s;">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-red-500/20 to-red-500/5 flex items-center justify-center mb-4">
              <Heart class="w-6 h-6 text-red-400" />
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Victim-Centered Design</h3>
            <p class="text-text-secondary text-sm">
              Every process designed with trauma-informed principles, recognizing that land documentation is intertwined with painful histories and healing.
            </p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Implementation Roadmap</h2>

        <div class="relative">
          <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-px bg-border"></div>

          <div class="space-y-12">
            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-accent font-medium mb-1">Q1 2024</div>
                  <div class="font-semibold text-text-primary">Pilot Launch</div>
                  <div class="text-sm text-text-secondary">Initial deployment in Meta department with 500 families from peace community</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-accent border-4 border-background"></div>
              <div class="w-5/12"></div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12"></div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-green-400 border-4 border-background"></div>
              <div class="w-5/12 pl-8 animate-slideInLeft" style="animation-delay: 0.1s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-green-400 font-medium mb-1">Q2 2024</div>
                  <div class="font-semibold text-text-primary">Evidence Gathering</div>
                  <div class="text-sm text-text-secondary">Digitization of historical records and community testimony collection</div>
                </Card>
              </div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft" style="animation-delay: 0.2s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-blue-400 font-medium mb-1">Q3 2024</div>
                  <div class="font-semibold text-text-primary">Mediation Phase</div>
                  <div class="text-sm text-text-secondary">Community-based dispute resolution for overlapping claims</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-blue-400 border-4 border-background"></div>
              <div class="w-5/12"></div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12"></div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-purple-400 border-4 border-background"></div>
              <div class="w-5/12 pl-8 animate-slideInLeft" style="animation-delay: 0.3s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-purple-400 font-medium mb-1">Q4 2024</div>
                  <div class="font-semibold text-text-primary">Scale to Caquetá</div>
                  <div class="text-sm text-text-secondary">Expansion to second department with lessons learned</div>
                </Card>
              </div>
            </div>

            <div class="relative flex items-center justify-between">
              <div class="w-5/12 text-right pr-8 animate-slideInLeft" style="animation-delay: 0.4s;">
                <Card variant="glass" class="p-4 inline-block">
                  <div class="text-sm text-yellow-400 font-medium mb-1">2025</div>
                  <div class="font-semibold text-text-primary">National Integration</div>
                  <div class="text-sm text-text-secondary">Integration with national land restitution system</div>
                </Card>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-yellow-400 border-4 border-background"></div>
              <div class="w-5/12"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Partnership -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="animate-fadeInUp">
            <h2 class="text-3xl font-bold text-text-primary mb-6">Peace Process Partnership</h2>
            <p class="text-text-secondary leading-relaxed mb-6">
              TerraChain Colombia operates under a historic partnership framework, bringing together entities that rarely collaborate toward a shared vision of sustainable peace through land security.
            </p>

            <div class="space-y-4">
              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <Building class="w-5 h-5 text-accent" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">Unidad de Restitución de Tierras</div>
                  <div class="text-sm text-text-secondary">Colombian Land Restitution Unit</div>
                </div>
              </div>

              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center">
                  <Target class="w-5 h-5 text-blue-400" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">USAID Colombia</div>
                  <div class="text-sm text-text-secondary">Technical and financial support</div>
                </div>
              </div>

              <div class="flex items-center gap-4 p-4 rounded-xl bg-surface-hover">
                <div class="w-10 h-10 rounded-full bg-green-500/10 flex items-center justify-center">
                  <Heart class="w-5 h-5 text-green-400" />
                </div>
                <div>
                  <div class="font-medium text-text-primary">Comisión de la Verdad</div>
                  <div class="text-sm text-text-secondary">Truth Commission historical records</div>
                </div>
              </div>
            </div>
          </div>

          <div class="animate-fadeInUp" style="animation-delay: 0.2s;">
            <Card variant="gradient" class="p-8">
              <Quote class="w-10 h-10 text-accent/30 mb-4" />
              <blockquote class="text-xl text-text-primary leading-relaxed mb-6">
                "After 30 years of displacement, I never thought I would see my family's land again. TerraChain found records that even the government said were lost forever. Now my children will inherit what my grandparents built."
              </blockquote>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center">
                  <span class="text-accent font-bold">MC</span>
                </div>
                <div>
                  <div class="font-medium text-text-primary">María Camila R.</div>
                  <div class="text-sm text-text-secondary">Returnee, Meta Department</div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Expected Impact -->
    <section class="py-16 bg-surface/30">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-text-primary mb-12 text-center">Expected Impact</h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card variant="glass" class="p-6 text-center animate-fadeInUp">
            <div class="text-4xl font-bold text-accent mb-2">15,000</div>
            <div class="text-text-secondary">Families to be supported by 2026</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.1s;">
            <div class="text-4xl font-bold text-green-400 mb-2">85%</div>
            <div class="text-text-secondary">Target dispute resolution rate</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.2s;">
            <div class="text-4xl font-bold text-blue-400 mb-2">90%</div>
            <div class="text-text-secondary">Reduction in resolution time</div>
          </Card>

          <Card variant="glass" class="p-6 text-center animate-fadeInUp" style="animation-delay: 0.3s;">
            <div class="text-4xl font-bold text-purple-400 mb-2">$45M</div>
            <div class="text-text-secondary">Projected economic impact</div>
          </Card>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <Card variant="gradient" class="p-12 animate-fadeInUp">
          <h2 class="text-3xl font-bold text-text-primary mb-4">Support Peace Through Land Rights</h2>
          <p class="text-xl text-text-secondary mb-8">
            Download our comprehensive report on how blockchain technology is supporting Colombia's peace process and sustainable development goals.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/docs/colombia-peace-land-rights.pdf" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-accent text-background font-semibold hover:bg-accent/90 transition-all no-underline">
              <Download class="w-5 h-5" />
              Download Peace Report
            </a>
            <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border text-text-primary font-semibold hover:bg-surface-hover transition-all no-underline">
              Partner With Us
              <ArrowRight class="w-5 h-5" />
            </a>
          </div>
        </Card>
      </div>
    </section>

    <!-- Next Case Study -->
    <section class="py-16 border-t border-border">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between">
          <a href="/case-studies/ghana" class="group flex items-center gap-4 text-text-secondary hover:text-accent transition-colors">
            <ArrowLeft class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
            <div>
              <div class="text-sm">Previous Case Study</div>
              <div class="font-semibold text-text-primary group-hover:text-accent transition-colors">Ghana Urban Titling</div>
            </div>
          </a>

          <a href="/case-studies/india" class="group flex items-center gap-4 text-text-secondary hover:text-accent transition-colors text-right">
            <div>
              <div class="text-sm">Next Case Study</div>
              <div class="font-semibold text-text-primary group-hover:text-accent transition-colors">India Pilot</div>
            </div>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fadeInUp {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .animate-slideInLeft {
    animation: slideInLeft 0.6s ease-out forwards;
  }
</style>
