---
import BaseLayout from '@layouts/BaseLayout.astro';
import BentoGrid from '@components/shared/BentoGrid.astro';
import Card from '@components/shared/Card.astro';
import TopographyCard from '@components/cards/TopographyCard.astro';
import { Shield, Lock, Eye, Server, FileCode, Bug, Check, AlertTriangle, Mail, ExternalLink, Award } from 'lucide-astro';
---

<BaseLayout
  title="Security — TerraChain"
  description="TerraChain's security practices, certifications, and bug bounty program. Learn how we protect your data and land records."
>
  <div class="pt-24 pb-8">
    <BentoGrid>
      <!-- Hero Section -->
      <Card colSpan={2} class="min-h-[280px] relative overflow-hidden" stagger={1} glow>
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-radial from-accent/10 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-radial from-green/10 to-transparent rounded-full blur-2xl"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-4">
            <Shield class="w-5 h-5 text-accent" />
            <span class="text-xs text-accent font-mono uppercase tracking-wider">Security</span>
          </div>

          <h1 class="text-3xl md:text-4xl text-text-primary mb-4 leading-tight">
            Security is Our<br/>
            <span class="text-gradient-accent">Foundation</span>
          </h1>

          <p class="text-text-secondary max-w-lg mb-6">
            Protecting land rights means protecting data. We implement defense-in-depth security across all layers of our platform.
          </p>

          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 text-xs font-mono bg-green/10 border border-green/30 rounded-full text-green">SOC 2 Type II</span>
            <span class="px-3 py-1.5 text-xs font-mono bg-accent/10 border border-accent/30 rounded-full text-accent">ISO 27001</span>
            <span class="px-3 py-1.5 text-xs font-mono bg-gold/10 border border-gold/30 rounded-full text-gold">GDPR Compliant</span>
          </div>
        </div>
      </Card>

      <!-- Topography -->
      <TopographyCard label="SECURITY" stagger={2} />

      <!-- Cryptographic Security -->
      <Card colSpan={2} class="min-h-[280px]" stagger={3}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <Lock class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h2 class="text-xl text-text-primary">Cryptographic Security</h2>
            <p class="text-xs text-text-muted">Industry-standard encryption at every level</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="crypto-card p-4 bg-surface-hover rounded-lg border border-border">
            <h3 class="text-sm text-text-primary font-mono mb-3">Data at Rest</h3>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> AES-256 encryption</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Hardware Security Modules (HSM)</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Encrypted database backups</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Key rotation every 90 days</li>
            </ul>
          </div>
          <div class="crypto-card p-4 bg-surface-hover rounded-lg border border-border">
            <h3 class="text-sm text-text-primary font-mono mb-3">Data in Transit</h3>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> TLS 1.3 encryption</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Certificate pinning</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> HSTS enabled</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Perfect forward secrecy</li>
            </ul>
          </div>
          <div class="crypto-card p-4 bg-surface-hover rounded-lg border border-border">
            <h3 class="text-sm text-text-primary font-mono mb-3">Digital Signatures</h3>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Ed25519 signatures</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Multi-signature wallets</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Time-locked transactions</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Hardware wallet support</li>
            </ul>
          </div>
          <div class="crypto-card p-4 bg-surface-hover rounded-lg border border-border">
            <h3 class="text-sm text-text-primary font-mono mb-3">Data Integrity</h3>
            <ul class="space-y-2 text-xs text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> SHA-256 hashing</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Merkle tree verification</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Blockchain anchoring</li>
              <li class="flex items-center gap-2"><Check class="w-3 h-3 text-green" /> Tamper-evident logging</li>
            </ul>
          </div>
        </div>
      </Card>

      <!-- Infrastructure Security -->
      <Card colSpan={1} class="min-h-[280px]" stagger={4}>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <Server class="w-5 h-5 text-gold" />
          </div>
          <h3 class="heading-mono text-sm text-text-primary">Infrastructure</h3>
        </div>

        <div class="space-y-3">
          {[
            'Geo-distributed infrastructure',
            'DDoS protection (Cloudflare)',
            'Web Application Firewall',
            'Rate limiting & throttling',
            'Container isolation',
            'Network segmentation',
            'Intrusion detection systems',
            '24/7 monitoring',
          ].map((item, i) => (
            <div class="flex items-center gap-2 text-sm text-text-secondary" style={`--delay: ${i * 0.05}s`}>
              <Check class="w-4 h-4 text-green flex-shrink-0" />
              <span>{item}</span>
            </div>
          ))}
        </div>
      </Card>

      <!-- Operational Security -->
      <Card colSpan={2} class="min-h-[250px]" stagger={5}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-green/20 to-transparent border border-green/30 flex items-center justify-center">
            <Eye class="w-5 h-5 text-green" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary">Operational Security</h3>
            <p class="text-xs text-text-muted">Processes and controls</p>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="ops-card p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Access Control</h4>
            <ul class="space-y-1 text-xs text-text-muted">
              <li>Role-based permissions</li>
              <li>Multi-factor authentication</li>
              <li>Privileged access management</li>
              <li>Just-in-time access</li>
            </ul>
          </div>
          <div class="ops-card p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Change Management</h4>
            <ul class="space-y-1 text-xs text-text-muted">
              <li>Code review requirements</li>
              <li>Automated security scanning</li>
              <li>Staged deployments</li>
              <li>Rollback procedures</li>
            </ul>
          </div>
          <div class="ops-card p-4 bg-surface-hover rounded-lg border border-border">
            <h4 class="text-sm text-text-primary font-mono mb-2">Incident Response</h4>
            <ul class="space-y-1 text-xs text-text-muted">
              <li>24/7 security team</li>
              <li>Defined response playbooks</li>
              <li>Regular tabletop exercises</li>
              <li>Post-incident reviews</li>
            </ul>
          </div>
        </div>
      </Card>

      <!-- Compliance -->
      <Card colSpan={1} class="min-h-[250px]" stagger={6}>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-copper/20 to-transparent border border-copper/30 flex items-center justify-center">
            <Award class="w-5 h-5 text-copper" />
          </div>
          <h3 class="heading-mono text-sm text-text-primary">Compliance</h3>
        </div>

        <div class="space-y-3">
          <div class="compliance-item p-3 bg-surface-hover rounded-lg border border-border">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-primary font-mono">SOC 2 Type II</span>
              <span class="text-xs text-green">Certified</span>
            </div>
            <p class="text-xs text-text-muted">Annual audit by independent firm</p>
          </div>
          <div class="compliance-item p-3 bg-surface-hover rounded-lg border border-border">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-primary font-mono">ISO 27001</span>
              <span class="text-xs text-green">Certified</span>
            </div>
            <p class="text-xs text-text-muted">Information security management</p>
          </div>
          <div class="compliance-item p-3 bg-surface-hover rounded-lg border border-border">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-primary font-mono">GDPR</span>
              <span class="text-xs text-green">Compliant</span>
            </div>
            <p class="text-xs text-text-muted">European data protection</p>
          </div>
          <div class="compliance-item p-3 bg-surface-hover rounded-lg border border-border">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-primary font-mono">LADM</span>
              <span class="text-xs text-green">Compliant</span>
            </div>
            <p class="text-xs text-text-muted">Land administration standard</p>
          </div>
        </div>
      </Card>

      <!-- Smart Contract Security -->
      <Card colSpan={2} class="min-h-[250px]" stagger={7}>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
            <FileCode class="w-5 h-5 text-accent" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary">Smart Contract Security</h3>
            <p class="text-xs text-text-muted">Audited and formally verified</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6">
          <div>
            <h4 class="text-sm text-text-primary font-mono mb-3">Security Measures</h4>
            <ul class="space-y-2 text-sm text-text-secondary">
              <li class="flex items-center gap-2"><Check class="w-4 h-4 text-green" /> Rust + Anchor framework</li>
              <li class="flex items-center gap-2"><Check class="w-4 h-4 text-green" /> Formal verification</li>
              <li class="flex items-center gap-2"><Check class="w-4 h-4 text-green" /> Multiple independent audits</li>
              <li class="flex items-center gap-2"><Check class="w-4 h-4 text-green" /> Time-locked upgrades</li>
              <li class="flex items-center gap-2"><Check class="w-4 h-4 text-green" /> Multi-sig admin controls</li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm text-text-primary font-mono mb-3">Audit Reports</h4>
            <div class="space-y-2">
              <a href="#" class="audit-link flex items-center justify-between p-2 bg-surface-hover rounded-lg hover:bg-surface border border-transparent hover:border-border transition-all no-underline">
                <div>
                  <span class="text-sm text-text-primary">OtterSec Audit</span>
                  <span class="text-xs text-text-muted block">Dec 2024</span>
                </div>
                <ExternalLink class="w-4 h-4 text-text-muted" />
              </a>
              <a href="#" class="audit-link flex items-center justify-between p-2 bg-surface-hover rounded-lg hover:bg-surface border border-transparent hover:border-border transition-all no-underline">
                <div>
                  <span class="text-sm text-text-primary">Trail of Bits Audit</span>
                  <span class="text-xs text-text-muted block">Sep 2024</span>
                </div>
                <ExternalLink class="w-4 h-4 text-text-muted" />
              </a>
              <a href="#" class="audit-link flex items-center justify-between p-2 bg-surface-hover rounded-lg hover:bg-surface border border-transparent hover:border-border transition-all no-underline">
                <div>
                  <span class="text-sm text-text-primary">Kudelski Security</span>
                  <span class="text-xs text-text-muted block">Jun 2024</span>
                </div>
                <ExternalLink class="w-4 h-4 text-text-muted" />
              </a>
            </div>
          </div>
        </div>
      </Card>

      <!-- Bug Bounty -->
      <Card colSpan={1} class="min-h-[250px] relative overflow-hidden group" stagger={8} glow accent>
        <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-accent/20 to-transparent border border-accent/30 flex items-center justify-center">
              <Bug class="w-5 h-5 text-accent" />
            </div>
            <h3 class="heading-mono text-sm text-text-primary">Bug Bounty</h3>
          </div>

          <p class="text-text-secondary text-sm mb-4">
            Help us keep TerraChain secure. We reward responsible disclosure of security vulnerabilities.
          </p>

          <div class="bg-surface-hover p-4 rounded-lg border border-border mb-4">
            <div class="text-center">
              <span class="text-3xl font-mono text-accent">$100K</span>
              <p class="text-xs text-text-muted">Maximum bounty</p>
            </div>
          </div>

          <div class="space-y-2 text-xs text-text-muted mb-4">
            <p><strong class="text-text-primary">Critical:</strong> Up to $100,000</p>
            <p><strong class="text-text-primary">High:</strong> Up to $25,000</p>
            <p><strong class="text-text-primary">Medium:</strong> Up to $5,000</p>
            <p><strong class="text-text-primary">Low:</strong> Up to $500</p>
          </div>

          <a href="mailto:security@terrachain.xyz" class="btn btn-primary w-full inline-flex items-center justify-center gap-2 no-underline text-sm">
            <span>Report Vulnerability</span>
          </a>
        </div>
      </Card>

      <!-- Security Contact -->
      <Card colSpan={2} class="min-h-[180px]" stagger={9}>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-gold/20 to-transparent border border-gold/30 flex items-center justify-center">
            <AlertTriangle class="w-5 h-5 text-gold" />
          </div>
          <div>
            <h3 class="heading-mono text-lg text-text-primary">Report a Security Issue</h3>
            <p class="text-xs text-text-muted">Responsible disclosure</p>
          </div>
        </div>

        <p class="text-text-secondary text-sm mb-4">
          If you believe you've found a security vulnerability in TerraChain, please report it responsibly. Do not disclose the issue publicly until we've had a chance to address it.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="mailto:security@terrachain.xyz" class="inline-flex items-center gap-2 text-accent hover:underline">
            <Mail class="w-4 h-4" />
            <span class="text-sm font-mono">security@terrachain.xyz</span>
          </a>
          <span class="text-text-muted text-sm">PGP Key: <code class="text-accent">0xABC123...</code></span>
        </div>
      </Card>

      <!-- Topography -->
      <TopographyCard stagger={10} />
    </BentoGrid>
  </div>
</BaseLayout>

<style>
  .text-gradient-accent {
    background: linear-gradient(135deg, var(--color-accent), var(--color-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-copper {
    color: var(--color-copper);
  }

  .crypto-card,
  .ops-card,
  .compliance-item {
    animation: fadeInUp 0.4s ease-out forwards;
    opacity: 0;
  }

  .crypto-card:nth-child(1) { animation-delay: 0.1s; }
  .crypto-card:nth-child(2) { animation-delay: 0.2s; }
  .crypto-card:nth-child(3) { animation-delay: 0.3s; }
  .crypto-card:nth-child(4) { animation-delay: 0.4s; }

  .ops-card:nth-child(1) { animation-delay: 0.1s; }
  .ops-card:nth-child(2) { animation-delay: 0.2s; }
  .ops-card:nth-child(3) { animation-delay: 0.3s; }

  .compliance-item:nth-child(1) { animation-delay: 0.1s; }
  .compliance-item:nth-child(2) { animation-delay: 0.2s; }
  .compliance-item:nth-child(3) { animation-delay: 0.3s; }
  .compliance-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crypto-card,
    .ops-card,
    .compliance-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
